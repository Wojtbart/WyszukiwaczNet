@code {
    private string searchPhrase = string.Empty;
    private bool isLoading = false;
    private bool setOlxGrid = false;
    private bool setBrzozowiakGrid = false;

    private void SelectAll() => setOlxGrid = setBrzozowiakGrid = setSprzedajemyGrid = setOtomotoGrid = true;
    private void DeselectAll() => setOlxGrid = setBrzozowiakGrid = setSprzedajemyGrid = setOtomotoGrid = false;
    private bool setSprzedajemyGrid = false;
    private bool setOtomotoGrid = false;

    private IEnumerable<ScrapedItem>? olxData;
    private IEnumerable<ScrapedItem>? brzozowiakData;
    private IEnumerable<ScrapedItem>? sprzedajemyData;
    private IEnumerable<ScrapedItem>? otomotoData;

    DataModel model = new();

    private async Task LoadData()
    {
        if (string.IsNullOrWhiteSpace(searchPhrase))
        {
            await DialogService.Alert(Loc["FillBrandOrModel"]);
            return;
        }
        if (!Globals.IsPhraseValid(searchPhrase))
        {
            await DialogService.Alert(Loc["InvalidPhrase"]);
            return;
        }

        isLoading = true;

        var websites = new List<string>();
        if (setOlxGrid) websites.Add("olxciagniki");
        if (setBrzozowiakGrid) websites.Add("brzozowiak");
        if (setSprzedajemyGrid) websites.Add("sprzedajemyciagniki");
        if (setOtomotoGrid) websites.Add("otomotorolnicze");

        model = new DataModel
        {
            websites = websites,
            phrase = searchPhrase,
            request_number = "30",
            additional_phrase = ""
        };

        try
        {
            var result = await DataProxy.getData(model);
            olxData = result?.Data?.OlxciagnikiData?.Output;
            brzozowiakData = result?.Data?.BrzozowiakData?.Output;
            sprzedajemyData = result?.Data?.SprzedajemyciagnikiData?.Output;
            otomotoData = result?.Data?.OtomotorolniczeData?.Output;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"{Loc["ErrorFetching"]} {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
