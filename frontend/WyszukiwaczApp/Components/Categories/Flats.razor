@page "/apartments"

@using WyszukiwaczAppDTO
@using System.Threading.Tasks
@inject DataProxy DataProxy
@inject DialogService DialogService
@inject IStringLocalizer<SharedResource> Loc

<style>
    .link {
        background-color: #a04ba7;
        border: none;
        color: white;
        padding: 6px 19px;
        text-decoration: none !important;
        display: inline-block;
        border: 1px solid #7c658b;
        cursor: pointer;
        border-radius: 12px;
        transition: background-color 0.3s, transform 0.3s;
    }

    .link:hover, .link:visited {
        color: #7c658b;
        text-decoration: none !important;
        background-color: white;
        border: 2px solid #7c658b;
    }

    .link:active {
        box-shadow: none;
        color: white;
        text-decoration: none !important;
    }

    .rz-form-field-content {
        outline: none !important;
        border-radius: 15px;
    }

    .grid-margin {
        margin-bottom: 20px;
        box-shadow: 0 0 50px #ccc;
    }
</style>

<RadzenRow AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="1rem" Class="rz-p-sm-12">
    <RadzenColumn Size="12" SizeMD="12" SizeLG="12">
        <RadzenFormField Text="Szukane miasto" Variant="Variant.Flat" Style="width:300px;">
            <RadzenTextBox @bind-Value="@textBoxValue" Placeholder="Wpisz nazwę miasta..." Style="width:100%; border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="Rodzaj transakcji" Variant="Variant.Flat" Style="width:200px;">
            <RadzenDropDown @bind-Value=@selectedOption1 Data=@options1 Style="width:100%;" AllowClear="true" Change="UpdateAdditionalPhrase" Placeholder="Wybierz..." />
        </RadzenFormField>
        <RadzenFormField Text="Typ oferty" Variant="Variant.Flat" Style="width:180px;">
            <RadzenDropDown @bind-Value=@selectedOption2 Data=@options2 Style="width:100%;" AllowClear="true" Change="UpdateAdditionalPhrase" Placeholder="Wybierz..." />
        </RadzenFormField>
        <RadzenFormField Text="Aktualność" Variant="Variant.Flat" Style="width:190px;">
            <RadzenDropDown @bind-Value=@selectedOption3 Data=@options3Items TextProperty="Display" ValueProperty="Value" Style="width:100%;" AllowClear="true" Change="UpdateAdditionalPhrase" Placeholder="Wybierz..." />
        </RadzenFormField>
        <RadzenFormField Text="Cena od (PLN)" Variant="Variant.Flat" Style="width:155px;">
            <RadzenNumeric @bind-Value="@selectedPriceFrom" TValue="int?" Min="0" Style="border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="Cena do (PLN)" Variant="Variant.Flat" Style="width:155px;">
            <RadzenNumeric @bind-Value="@selectedPriceTo" TValue="int?" Min="0" Style="border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="Pow. od (m²)" Variant="Variant.Flat" Style="width:140px;">
            <RadzenNumeric @bind-Value="@selectedAreaFrom" TValue="int?" Min="0" Style="border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="Pow. do (m²)" Variant="Variant.Flat" Style="width:140px;">
            <RadzenNumeric @bind-Value="@selectedAreaTo" TValue="int?" Min="0" Style="border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="Pokoje (OtoDom)" Variant="Variant.Flat" Style="width:185px;">
            <RadzenDropDown TValue="int?" @bind-Value="@selectedRooms" Data="@roomOptions" TextProperty="Label" ValueProperty="Value" Placeholder="Dowolna" AllowClear="true" Style="width:100%;" />
        </RadzenFormField>
        <RadzenFormField Variant="Variant.Flat" Style="width:150px; border-radius:15px !important;">
            <RadzenButton Click=LoadData Text="SZUKAJ" Icon="search" ButtonStyle="ButtonStyle.Primary" Shade="Shade.Dark" Style="height:3.25rem; border-radius:15px;" />
        </RadzenFormField>
        <a href="/notification_settings?category=Nieruchomo%C5%9Bci" style="display:inline-flex; align-items:center; gap:0.4rem; padding:0 1.2rem; height:3.25rem; background:#a04ba7; color:white; text-decoration:none; border-radius:15px; font-size:0.875rem; font-weight:600; border:1px solid #7c658b; cursor:pointer; white-space:nowrap; transition:background 0.2s; vertical-align:middle; margin-left:0.5rem;">
            🔔 @Loc["SetRecurringNotifications"]
        </a>
    </RadzenColumn>
</RadzenRow>

<RadzenText TextStyle="TextStyle.H4" Text="Wybierz strony, z których chcesz pobrać ogłoszenia" Style="color:red; margin-bottom:20px;" />

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter">
    <RadzenImage Path="images/otoDom.png" Style="width: 4rem;height:2rem;" AlternateText="OtoDom" />
    <RadzenLabel Text="OtoDom" Component="CheckBox2" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setOtoDomGrid Name="CheckBox2" />
</RadzenButton>

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter" Style="margin-bottom:30px;">
    <RadzenImage Path="images/olx.png" Style="width: 2rem;height:2rem;" AlternateText="OLX Nieruchomości" />
    <RadzenLabel Text="OLX Nieruchomości" Component="CheckBoxOlxNieruch" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setOlxNieruchomosciGrid Name="CheckBoxOlxNieruch" />
</RadzenButton>

@if (setOtoDomGrid)
{
    <RadzenDataGrid Data="@otoDomData" style="--rz-grid-header-text-transform: none; --rz-grid-header-font-size: 1rem;"
                    AllowFiltering="true" AllowColumnResize="true" AllowAlternatingRows="false" AllowColumnReorder="true"
                    FilterMode="FilterMode.Advanced" AllowSorting="true" PageSize="10" AllowPaging="true"
                    PagerHorizontalAlign="HorizontalAlign.Center" FilterPopupRenderMode="PopupRenderMode.OnDemand"
                    class="grid-margin" IsLoading="isLoading" ShowPagingSummary="true"
                    LogicalFilterOperator="LogicalFilterOperator.Or" SelectionMode="DataGridSelectionMode.Single">
        <EmptyTemplate>
            <p style="color: lightgrey; font-size: 24px; text-align: center; margin: 2rem;">Brak danych</p>
        </EmptyTemplate>
        <HeaderTemplate>
            <RadzenImage Path="images/otoDom.png" Style="width: 6rem; height:3rem;" AlternateText="OtoDom" />
            <h3 style="display: inline-block; margin-left:10px; color:red; font-weight:bold;">OtoDom</h3>
        </HeaderTemplate>
        <Columns>
            <RadzenDataGridColumn Property="Title" Title="Tytuł" Frozen="true" Width="300px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText TextStyle="TextStyle.H6" style="font-weight:bold; white-space:pre-wrap">@context.Title</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Url" Title="Link" Width="150px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <div class="rz-text-align-center" style="height:38px;">
                        <RadzenLink Path="@context.Url" Text="Otwórz link" Target="_blank" class="link" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="ImageUrl" Title="Zdjęcie" Sortable="false" Filterable="false" Width="120px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    @if (string.IsNullOrWhiteSpace(context.ImageUrl) || context.ImageUrl == "No image")
                    { <div style="color: gray; font-style: italic;">Brak zdjęcia</div> }
                    else
                    { <RadzenImage Path="@context.ImageUrl" Style="width:4rem;height:4rem;" /> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Price" Title="Cena (PLN)" TextAlign="TextAlign.Center">
                <Template Context="context">@Globals.FormatPrice(context.Price)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Location" Title="Lokalizacja" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@context.Location</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="SellerName" Title="Sprzedający" TextAlign="TextAlign.Center" />
            <RadzenDataGridColumn Property="AdditionalInfo" Title="Szczegóły" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@context.AdditionalInfo</RadzenText>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@if (setOlxNieruchomosciGrid)
{
    <RadzenDataGrid Data="@olxNieruchomosciData" style="--rz-grid-header-text-transform: none; --rz-grid-header-font-size: 1rem;"
                    AllowFiltering="true" AllowColumnResize="true" AllowAlternatingRows="false" AllowColumnReorder="true"
                    FilterMode="FilterMode.Advanced" AllowSorting="true" PageSize="10" AllowPaging="true"
                    PagerHorizontalAlign="HorizontalAlign.Center" FilterPopupRenderMode="PopupRenderMode.OnDemand"
                    class="grid-margin" IsLoading="isLoading" ShowPagingSummary="true"
                    LogicalFilterOperator="LogicalFilterOperator.Or" SelectionMode="DataGridSelectionMode.Single">
        <EmptyTemplate>
            <p style="color: lightgrey; font-size: 24px; text-align: center; margin: 2rem;">Brak danych</p>
        </EmptyTemplate>
        <HeaderTemplate>
            <RadzenImage Path="images/olx.png" Style="width: 4rem; height:4rem;" AlternateText="OLX" />
            <h3 style="display: inline-block; margin-left:10px; color:red; font-weight:bold;">OLX Nieruchomości</h3>
        </HeaderTemplate>
        <Columns>
            <RadzenDataGridColumn Property="Title" Title="Tytuł" Frozen="true" Width="300px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText TextStyle="TextStyle.H6" style="font-weight:bold; white-space:pre-wrap">@context.Title</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Url" Title="Link" Width="150px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <div class="rz-text-align-center" style="height:38px;">
                        <RadzenLink Path="@context.Url" Text="Otwórz link" Target="_blank" class="link" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="ImageUrl" Title="Zdjęcie" Sortable="false" Filterable="false" Width="120px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    @if (string.IsNullOrWhiteSpace(context.ImageUrl) || context.ImageUrl == "No image")
                    { <div style="color: gray; font-style: italic;">Brak zdjęcia</div> }
                    else
                    { <RadzenImage Path="@context.ImageUrl" Style="width:4rem;height:4rem;" /> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Price" Title="Cena (PLN)" TextAlign="TextAlign.Center">
                <Template Context="context">@Globals.FormatPrice(context.Price)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Location" Title="Lokalizacja" TextAlign="TextAlign.Center">
                <Template Context="context">
                    @{
                        var loc = context.Location;
                        var dash = loc?.IndexOf(" - ") ?? -1;
                    }
                    @(dash >= 0 ? loc!.Substring(0, dash) : loc)
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Location" Title="Data" TextAlign="TextAlign.Center">
                <Template Context="context">
                    @{
                        var loc2 = context.Location;
                        var dash2 = loc2?.IndexOf(" - ") ?? -1;
                    }
                    @(dash2 >= 0 ? loc2!.Substring(dash2 + 3) : "")
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="AdditionalInfo" Title="Szczegóły" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@context.AdditionalInfo</RadzenText>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code
{
    private record ActivityOpt(string Value, string Display);

    List<string> options1 = new() { "sprzedaz", "wynajem" };
    List<string> options2 = new() { "prywatne", "publiczne" };
    List<ActivityOpt> options3Items = new()
    {
        new("ostatnie24h", "z ostatnich 24h"),
        new("dowolna", "dowolna"),
    };

    string? selectedOption1;
    string? selectedOption2;
    string? selectedOption3;

    private int? selectedPriceFrom;
    private int? selectedPriceTo;
    private int? selectedAreaFrom;
    private int? selectedAreaTo;
    private int? selectedRooms;

    private record RoomOpt(string Label, int Value);
    private List<RoomOpt> roomOptions = new()
    {
        new("1 pokój", 1), new("2 pokoje", 2), new("3 pokoje", 3), new("4 pokoje", 4), new("5+", 5)
    };

    private bool isLoading = false;
    private bool setOtoDomGrid = false;
    private bool setOlxNieruchomosciGrid = false;

    private IEnumerable<ScrapedItem>? otoDomData;
    private IEnumerable<ScrapedItem>? olxNieruchomosciData;

    private string textBoxValue = string.Empty;

    DataModel model = new();

    void UpdateAdditionalPhrase()
    {
        model.additional_phrase = string.Join(" ",
            new[] { selectedOption1, selectedOption2, selectedOption3 }
            .Where(x => !string.IsNullOrWhiteSpace(x)));
    }

    private async Task LoadData()
    {
        if (setOtoDomGrid && (string.IsNullOrWhiteSpace(selectedOption1) ||
            string.IsNullOrWhiteSpace(selectedOption2) ||
            string.IsNullOrWhiteSpace(selectedOption3)))
        {
            await DialogService.Alert("Dla OtoDom uzupełnij wszystkie pola wyboru (rodzaj, typ, aktualność).");
            return;
        }

        if (!setOtoDomGrid && !setOlxNieruchomosciGrid)
        {
            await DialogService.Alert("Zaznacz co najmniej jedną stronę, z której chcesz pobrać dane.");
            return;
        }

        if (string.IsNullOrWhiteSpace(textBoxValue))
        {
            await DialogService.Alert("Wypełnij pole Szukane miasto.");
            return;
        }
        if (!Globals.IsPhraseValid(textBoxValue))
        {
            await DialogService.Alert("Fraza zawiera niedozwolone znaki. Dozwolone: litery, cyfry, spacje, myślnik.");
            return;
        }

        isLoading = true;

        var websites = new List<string>();
        if (setOtoDomGrid) websites.Add("otoDom");
        if (setOlxNieruchomosciGrid) websites.Add("olxnieruchomosci");

        model = new DataModel
        {
            websites = websites,
            additional_phrase = model.additional_phrase,
            phrase = textBoxValue,
            request_number = "30",
            price_from = selectedPriceFrom,
            price_to = selectedPriceTo,
            area_from = selectedAreaFrom,
            area_to = selectedAreaTo,
            rooms = selectedRooms,
        };

        try
        {
            var result = await DataProxy.getData(model);
            if (result == null || !result.Success)
            {
                await DialogService.Alert(result?.Message ?? "Błąd podczas pobierania danych.");
                return;
            }
            otoDomData = result.Data?.OtoDomData?.Output ?? Enumerable.Empty<ScrapedItem>();
            olxNieruchomosciData = result.Data?.OlxnieruchomosciData?.Output ?? Enumerable.Empty<ScrapedItem>();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"Błąd podczas pobierania danych: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
