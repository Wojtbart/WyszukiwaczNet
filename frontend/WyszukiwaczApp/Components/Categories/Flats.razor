@page "/flats"

@using WyszukiwaczAppDTO
@using System.Threading.Tasks
@inject DataProxy DataProxy
@inject DialogService DialogService

<RadzenRow AlignItems="AlignItems.Start" Wrap="FlexWrap.Wrap" Style="margin-bottom:20px;">

    <RadzenColumn Size="12" SizeMD="4" Style="padding:10px;">
        <RadzenLabel Text="Szukane miasto" />
        <RadzenTextBox @bind-Value="@textBoxValue"
                       Style="width: 100%; border-radius:15px;"
                       Placeholder="Wpisz nazwę miasta..." />
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="2" Style="padding:10px;">
        <RadzenLabel Text="Rodzaj transakcji" />
        <RadzenDropDown @bind-Value=@selectedOption1
                        Data=@options1
                        Style="width: 100%;"
                        AllowClear="true"
                        Change="UpdateAdditionalPhrase"
                        Placeholder="Wybierz..." />
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="2" Style="padding:10px;">
        <RadzenLabel Text="Typ oferty" />
        <RadzenDropDown @bind-Value=@selectedOption2
                        Data=@options2
                        Style="width: 100%;"
                        AllowClear="true"
                        Change="UpdateAdditionalPhrase"
                        Placeholder="Wybierz..." />
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="2" Style="padding:10px;">
        <RadzenLabel Text="Aktualność" />
        <RadzenDropDown @bind-Value=@selectedOption3
                        Data=@options3
                        Style="width: 100%;"
                        AllowClear="true"
                        Change="UpdateAdditionalPhrase"
                        Placeholder="Wybierz..." />
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="2" Style="padding:10px; display:flex; align-items:flex-end;">
        <RadzenButton Click=LoadData
                      Text="SZUKAJ"
                      Icon="search"
                      ButtonStyle="ButtonStyle.Primary"
                      Shade="Shade.Dark"
                      Style="width:100%; text-align:center;height:4rem; border-radius:15px;" />
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="2" Style="padding:10px; display:flex; align-items:flex-end;">
        <a href="/notification_settings" style="display:flex; align-items:center; justify-content:center; gap:0.4rem; width:100%; height:4rem; background:#a04ba7; color:white; text-decoration:none; border-radius:15px; font-size:0.875rem; font-weight:600; border:1px solid #7c658b; cursor:pointer; white-space:nowrap; transition:background 0.2s;">
            🔔 Ustaw powiadomienia cykliczne
        </a>
    </RadzenColumn>

</RadzenRow>

<RadzenText TextStyle="TextStyle.H4" Text="Wybierz strony, z których chcesz pobrać ogłoszenia" Style="color:red; margin-bottom:20px;" />

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter">
    <RadzenImage Path="images/otoDom.png" Style="width: 4rem;height:2rem;" AlternateText="OtoDom" />
    <RadzenLabel Text="OtoDom" Component="CheckBox2" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setOtoDomGrid Name="CheckBox2" />
</RadzenButton>


@if (setOtoDomGrid)
{
    <RadzenDataGrid Data="@otoDomData"
                    AllowFiltering="true"
                    AllowSorting="true"
                    AllowPaging="true"
                    AllowColumnResize="true"
                    ColumnWidthMode="ColumnWidthMode.Fit"
                    PageSize="10"
                    IsLoading="isLoading"
                    Class="grid-margin"
                    Style="word-wrap: break-word; white-space: normal;">

        <Columns>

            <RadzenDataGridColumn Property="Title" Title="Tytuł" Width="250px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <div style="white-space: normal; line-height:1.3;font-weight:bold;">
                        @context.Title
                    </div>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Property="Url" Title="Link" Width="150px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <div class="rz-text-align-center" style="height:38px;">
                        <RadzenLink Path="@context.Url" Text="Otwórz link" Target="_blank" class="link" />
                    </div>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Property="ImageUrl" Title="Zdjęcie" Sortable="false" Width="140px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    @if (string.IsNullOrWhiteSpace(context.ImageUrl) || context.ImageUrl == "No image")
                    {
                        <div style="color: gray; font-style: italic; font-size: 0.9rem;">
                            Brak zdjęcia
                        </div>
                    }
                    else
                    {
                        <RadzenImage Path="@context.ImageUrl" Style="width:4rem;height:4rem;" />
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Property="Price" Title="Cena (PLN)" Width="120px" TextAlign="TextAlign.Center">
                <Template Context="context">@((int?)context.Price)</Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Property="Location" Title="Lokalizacja" Width="200px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <div style="white-space: normal;">
                        @context.Location
                    </div>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Property="AdditionalInfo" Title="Dodatkowe informacje" Width="250px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <div style="white-space: normal;">
                        @context.AdditionalInfo
                    </div>
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code 
{
    List<string> options1 = new() { "sprzedaz", "wynajem" };
    List<string> options2 = new() { "prywatne", "publiczne" };
    List<string> options3 = new() { "ostatnie 24 godziny", "dowolna" };

    string? selectedOption1;
    string? selectedOption2;
    string? selectedOption3;

    private bool isLoading = false;
    private bool setOtoDomGrid = false;

    private IEnumerable<ScrapedItem>? otoDomData;

    private string textBoxValue = string.Empty;

    DataModel model = new();

    void UpdateAdditionalPhrase()
    {
        model.additional_phrase = string.Join(" ",
            new[] { selectedOption1, selectedOption2, selectedOption3 }
            .Where(x => !string.IsNullOrWhiteSpace(x)));
    }

    private async Task LoadData()
    {
        if (string.IsNullOrWhiteSpace(selectedOption1) ||
            string.IsNullOrWhiteSpace(selectedOption2) ||
            string.IsNullOrWhiteSpace(selectedOption3))
        {
            await DialogService.Alert("Uzupełnij wszystkie pola wyboru (rodzaj, typ, aktualność).");
            return;
        }

        if (!setOtoDomGrid)
        {
            await DialogService.Alert("Zaznacz co najmniej jedną stronę, z której chcesz pobrać dane.");
            return;
        }

        if (string.IsNullOrWhiteSpace(textBoxValue))
        {
            await DialogService.Alert("Wypełnij pole Szukane miasto.");
            return;
        }
        if (!Globals.IsPhraseValid(textBoxValue))
        {
            await DialogService.Alert("Fraza zawiera niedozwolone znaki. Dozwolone: litery, cyfry, spacje, myślnik.");
            return;
        }

        isLoading = true;

        var websites = new List<string>();
        if (setOtoDomGrid) websites.Add("otoDom");

        model = new DataModel
        {
            websites = websites,
            additional_phrase = model.additional_phrase,
            phrase = textBoxValue,
            request_number = "30"
        };

        try
        {
            var result = await DataProxy.getData(model);

            otoDomData = result?.Data?.OtoDomData?.Output
                         ?? Enumerable.Empty<ScrapedItem>();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"Błąd podczas pobierania danych: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

}