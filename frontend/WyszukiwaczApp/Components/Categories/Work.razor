@code {
    private string searchedKeyword = string.Empty;
    private string workLocation = string.Empty;
    private int? employmentLevel = null;
    private int? contractType = null;
    private bool isLoading = false;
    private bool setPracujGrid = false;
    private bool setJJIGrid = false;
    private bool setNFJGrid = false;
    private bool setTPGrid = false;
    private bool setBulldogGrid = false;
    private IEnumerable<ScrapedItem>? pracujData;
    private IEnumerable<ScrapedItem>? jjiData;
    private IEnumerable<ScrapedItem>? nfjData;
    private IEnumerable<ScrapedItem>? tpData;
    private IEnumerable<ScrapedItem>? bulldogData;

    private record FilterOption(string Label, int? Value);
    private static readonly List<FilterOption> employmentLevels = new()
    {
        new("Dowolny", null),
        new("Junior", 17),
        new("Mid / Regular", 4),
        new("Senior", 18),
        new("Ekspert", 19),
    };
    private static readonly List<FilterOption> contractTypes = new()
    {
        new("Dowolna", null),
        new("Umowa o pracę", 0),
        new("B2B", 3),
    };

    DataModel model = new();

    private async Task LoadData()
    {
        if (string.IsNullOrWhiteSpace(searchedKeyword))
        {
            await DialogService.Alert("Wpisz stanowisko lub słowo kluczowe.");
            return;
        }
        if (!Globals.IsPhraseValid(searchedKeyword))
        {
            await DialogService.Alert("Fraza zawiera niedozwolone znaki. Dozwolone: litery, cyfry, spacje, myślnik, #, .");
            return;
        }

        isLoading = true;

        var websites = new List<string>();
        if (setPracujGrid) websites.Add("pracuj");
        if (setJJIGrid) websites.Add("justjoinit");
        if (setNFJGrid) websites.Add("nofluffjobs");
        if (setTPGrid) websites.Add("theprotocolit");
        if (setBulldogGrid) websites.Add("bulldogjob");

        model = new DataModel
        {
            websites = websites,
            phrase = searchedKeyword,
            request_number = "30",
            additional_phrase = "",
            work_location = string.IsNullOrWhiteSpace(workLocation) ? null : workLocation.Trim(),
            employment_level = employmentLevel,
            contract_type = contractType,
        };

        try
        {
            var result = await DataProxy.getData(model);
            pracujData = result?.Data?.PracujData?.Output;
            jjiData = result?.Data?.JustjoinitData?.Output;
            nfjData = result?.Data?.NofluffjobsData?.Output;
            tpData = result?.Data?.TheprotocolitData?.Output;
            bulldogData = result?.Data?.BulldogjobData?.Output;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"Błąd podczas pobierania danych: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
