@page "/work"

@using WyszukiwaczAppDTO
@using System.Threading.Tasks
@inject DataProxy DataProxy
@inject DialogService DialogService
@inject IStringLocalizer<SharedResource> Loc

<style>
    .link {
        background-color: #a04ba7;
        border: none;
        color: white;
        padding: 6px 19px;
        text-decoration: none !important;
        display: inline-block;
        border: 1px solid #7c658b;
        cursor: pointer;
        border-radius: 12px;
        transition: background-color 0.3s, transform 0.3s;
    }

    .link:hover, .link:visited {
        color: #7c658b;
        text-decoration: none !important;
        background-color: white;
        border: 2px solid #7c658b;
    }

    .link:active {
        box-shadow: none;
        color: white;
        text-decoration: none !important;
    }

    .rz-form-field-content {
        outline: none !important;
        border-radius: 15px;
    }

    .grid-margin {
        margin-bottom: 20px;
        box-shadow: 0 0 50px #ccc;
    }
</style>

<RadzenRow AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="1rem" Class="rz-p-sm-12">
    <RadzenColumn Size="12" SizeMD="12" SizeLG="12">
        <RadzenFormField Text="@(Loc["PositionKeyword"].Value)" Variant="Variant.Flat" Style="width:35%;margin-right:20px;">
            <RadzenTextBox @bind-Value="@searchedKeyword" @oninput="@(e => searchedKeyword = e.Value?.ToString() ?? string.Empty)" Style="width: 100%; border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="@(Loc["WorkLocation"].Value)" Variant="Variant.Flat" Style="width:20%;margin-right:20px;">
            <RadzenTextBox @bind-Value="@workLocation" Placeholder="@(Loc["WorkLocationPlaceholder"].Value)" Style="width: 100%; border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="@(Loc["Seniority"].Value)" Variant="Variant.Flat" Style="width:180px;margin-right:20px;">
            <RadzenDropDown @bind-Value="@employmentLevel" Data="@employmentLevels" TextProperty="Label" ValueProperty="Value"
                            Placeholder="@(Loc["AnyM"].Value)" AllowClear="true" Style="width:100%;border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="@(Loc["ContractType"].Value)" Variant="Variant.Flat" Style="width:150px;margin-right:20px;">
            <RadzenDropDown @bind-Value="@contractType" Data="@contractTypes" TextProperty="Label" ValueProperty="Value"
                            Placeholder="@(Loc["AnyF"].Value)" AllowClear="true" Style="width:100%;border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Variant="Variant.Flat" Style="width: 150px; border-radius:15px !important;">
            <RadzenButton Click=LoadData Text="@(Loc["Load"].Value)" Icon="cached" ButtonStyle="ButtonStyle.Success" Shade="Shade.Darker" Style="height:3.25rem; border-radius:15px;" Disabled="@string.IsNullOrWhiteSpace(searchedKeyword)" />
        </RadzenFormField>
        <a href="/notification_settings?category=Praca" style="display:inline-flex; align-items:center; gap:0.4rem; padding:0 1.2rem; height:3.25rem; background:#a04ba7; color:white; text-decoration:none; border-radius:15px; font-size:0.875rem; font-weight:600; border:1px solid #7c658b; cursor:pointer; white-space:nowrap; transition:background 0.2s; vertical-align:middle; margin-left:0.5rem;">
            🔔 @Loc["SetRecurringNotifications"]
        </a>
    </RadzenColumn>
</RadzenRow>

<RadzenText TextStyle="TextStyle.H4" Text="@(Loc["ChooseJobPortals"].Value)" Style="color:red; margin-bottom:20px;" />

<RadzenButton Text="@(Loc["SelectAll"].Value)" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Style="margin-bottom:8px; margin-right:8px;" Click="SelectAll" />
<RadzenButton Text="@(Loc["DeselectAll"].Value)" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Style="margin-bottom:8px; margin-right:8px;" Click="DeselectAll" />

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter" Style="margin-bottom:30px;margin-right:12px;">
    <RadzenImage Path="images/pracuj.svg" Style="width:5rem;height:3rem;" AlternateText="Pracuj" />
    <RadzenLabel Text="Pracuj" Component="CheckBox1" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setPracujGrid Name="CheckBox1" />
</RadzenButton>

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter" Style="margin-bottom:30px;margin-right:12px;">
    <RadzenImage Path="images/justjoinit.png" Style="width:3rem;height:3rem;" AlternateText="JustJoinIt" />
    <RadzenLabel Text="JustJoin.IT" Component="CheckBox2" Style="margin:0.3rem; vertical-align: middle; font-weight:bold;" />
    <RadzenCheckBox @bind-Value=@setJJIGrid Name="CheckBox2" />
</RadzenButton>

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter" Style="margin-bottom:30px;margin-right:12px;">
    <RadzenImage Path="images/nofluffjobs.png" Style="width:3rem;height:3rem;" AlternateText="NoFluffJobs" />
    <RadzenLabel Text="NoFluffJobs" Component="CheckBox3" Style="margin:0.3rem; vertical-align: middle; font-weight:bold;" />
    <RadzenCheckBox @bind-Value=@setNFJGrid Name="CheckBox3" />
</RadzenButton>

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter" Style="margin-bottom:30px;margin-right:12px;">
    <RadzenImage Path="images/theprotocolit.png" Style="width:6rem;height:3rem;" AlternateText="TheProtocol.IT" />
    <RadzenLabel Text="TheProtocol.IT" Component="CheckBox4" Style="margin:0.3rem; vertical-align: middle; font-weight:bold;" />
    <RadzenCheckBox @bind-Value=@setTPGrid Name="CheckBox4" />
</RadzenButton>

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter" Style="margin-bottom:30px;margin-right:12px;">
    <RadzenImage Path="images/bulldogjob.svg" Style="width:5rem;height:3rem;" AlternateText="BulldogJob" />
    <RadzenLabel Text="BulldogJob" Component="CheckBox5" Style="margin:0.3rem; vertical-align: middle; font-weight:bold;" />
    <RadzenCheckBox @bind-Value=@setBulldogGrid Name="CheckBox5" />
</RadzenButton>

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter" Style="margin-bottom:30px;margin-right:12px;">
    <RadzenImage Path="images/solidjobs.svg" Style="width:5rem;height:3rem;" AlternateText="SolidJobs" />
    <RadzenLabel Text="Solid.Jobs" Component="CheckBox6" Style="margin:0.3rem; vertical-align: middle; font-weight:bold;" />
    <RadzenCheckBox @bind-Value=@setSolidJobsGrid Name="CheckBox6" />
</RadzenButton>


@if (setPracujGrid)
{
    <RadzenDataGrid Data="@pracujData" style="--rz-grid-header-text-transform: none; --rz-grid-header-font-size: 1rem;"
                    AllowFiltering="true" AllowColumnResize="true" AllowAlternatingRows="false" AllowColumnReorder="true"
                    FilterMode="FilterMode.Advanced" AllowSorting="true" PageSize="15" AllowPaging="true"
                    PagerHorizontalAlign="HorizontalAlign.Center" FilterPopupRenderMode="PopupRenderMode.OnDemand"
                    class="grid-margin" IsLoading="isLoading" ShowPagingSummary="true"
                    LogicalFilterOperator="LogicalFilterOperator.Or" SelectionMode="DataGridSelectionMode.Single">
        <EmptyTemplate>
            <p style="color: lightgrey; font-size: 24px; text-align: center; margin: 2rem;">@Loc["NoJobs"]</p>
        </EmptyTemplate>
        <HeaderTemplate>
            <h3 style="display: inline-block; color:red; font-weight:bold;">💼 Pracuj</h3>
        </HeaderTemplate>
        <Columns>
            <RadzenDataGridColumn Property="Title" Title="@(Loc["Position"].Value)" Frozen="true" Width="260px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText TextStyle="TextStyle.H6" style="font-weight:bold; white-space:pre-wrap">@context.Title</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Url" Title="@(Loc["Link"].Value)" Width="170px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <div class="rz-text-align-center" style="height:38px;">
                        <RadzenLink Path="@context.Url" Text="@(Loc["ViewOffer"].Value)" Target="_blank" class="link" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="SellerName" Title="@(Loc["Employer"].Value)" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@context.SellerName</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="@(Loc["Salary"].Value)" TextAlign="TextAlign.Center" Width="200px">
                <Template Context="context">
                    @if (context.JobDetail?.SalaryRaw != null)
                    {
                        <RadzenText style="white-space:pre-wrap; font-weight:bold; color:#2e7d32;">@context.JobDetail.SalaryRaw</RadzenText>
                    }
                    else if (context.Price.HasValue)
                    {
                        <RadzenText>@Loc["FromPLN"] @Globals.FormatPrice(context.Price) PLN</RadzenText>
                    }
                    else
                    {
                        <RadzenText style="color:#aaa;">—</RadzenText>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="@(Loc["Technologies"].Value)" TextAlign="TextAlign.Center" Width="200px">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap; font-size:0.85rem;">@(context.JobDetail?.Technologies ?? "—")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="@(Loc["WorkPlace"].Value)" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@(context.JobDetail?.WorkLocation ?? context.Location ?? "—")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="@(Loc["CompanyHQ"].Value)" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@(context.JobDetail?.HqLocation ?? "—")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="AdditionalInfo" Title="@(Loc["AdditionalInfoExt"].Value)" TextAlign="TextAlign.Center" Width="220px">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap; font-size:0.82rem;">@(context.AdditionalInfo ?? "—")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

