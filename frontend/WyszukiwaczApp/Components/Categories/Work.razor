                    <div class="rz-text-align-center" style="height:38px;">
                        <RadzenLink Path="@context.Url" Text="@(Loc["ViewOffer"].Value)" Target="_blank" class="link" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="SellerName" Title="@(Loc["Company"].Value)" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@context.SellerName</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="@(Loc["Salary"].Value)" TextAlign="TextAlign.Center" Width="220px">
                <Template Context="context">
                    @if (context.JobDetail?.SalaryRaw != null)
                    {
                        <RadzenText style="white-space:pre-wrap; font-weight:bold; color:#2e7d32;">@context.JobDetail.SalaryRaw</RadzenText>
                    }
                    else
                    {
                        <RadzenText style="color:#aaa;">—</RadzenText>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="@(Loc["Technologies"].Value)" TextAlign="TextAlign.Center" Width="220px">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap; font-size:0.85rem;">@(context.JobDetail?.Technologies ?? "—")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="@(Loc["WorkMode"].Value)" TextAlign="TextAlign.Center" Width="130px">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@(context.Location ?? "—")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="@(Loc["HQ"].Value)" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@(context.JobDetail?.HqLocation ?? "—")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private string searchedKeyword = string.Empty;
    private string workLocation = string.Empty;
    private int? employmentLevel = null;
    private int? contractType = null;
    private bool isLoading = false;
    private bool setPracujGrid = false;
    private bool setJJIGrid = false;
    private bool setNFJGrid = false;
    private bool setTPGrid = false;
    private bool setBulldogGrid = false;
    private bool setSolidJobsGrid = false;

    private void SelectAll() => setPracujGrid = setJJIGrid = setNFJGrid = setTPGrid = setBulldogGrid = setSolidJobsGrid = true;
    private void DeselectAll() => setPracujGrid = setJJIGrid = setNFJGrid = setTPGrid = setBulldogGrid = setSolidJobsGrid = false;

    private IEnumerable<ScrapedItem>? pracujData;
    private IEnumerable<ScrapedItem>? jjiData;
    private IEnumerable<ScrapedItem>? nfjData;
    private IEnumerable<ScrapedItem>? tpData;
    private IEnumerable<ScrapedItem>? bulldogData;
    private IEnumerable<ScrapedItem>? solidJobsData;

    private record FilterOption(string Label, int? Value);
    private List<FilterOption> employmentLevels => new()
    {
        new(Loc["AnyM"], null),
        new(Loc["LevelJunior"], 17),
        new(Loc["LevelMid"], 4),
        new(Loc["LevelSenior"], 18),
        new(Loc["LevelExpert"], 19),
    };
    private List<FilterOption> contractTypes => new()
    {
        new(Loc["AnyF"], null),
        new(Loc["ContractEmployment"], 0),
        new(Loc["ContractB2B"], 3),
        new(Loc["ContractMandate"], 2),
    };

    DataModel model = new();

    private async Task LoadData()
    {
        if (string.IsNullOrWhiteSpace(searchedKeyword))
        {
            await DialogService.Alert(Loc["EnterKeyword"]);
            return;
        }
        if (!Globals.IsPhraseValid(searchedKeyword))
        {
            await DialogService.Alert(Loc["InvalidPhraseExt"]);
            return;
        }

        isLoading = true;

        var websites = new List<string>();
        if (setPracujGrid) websites.Add("pracuj");
        if (setJJIGrid) websites.Add("justjoinit");
        if (setNFJGrid) websites.Add("nofluffjobs");
        if (setTPGrid) websites.Add("theprotocolit");
        if (setBulldogGrid) websites.Add("bulldogjob");
        if (setSolidJobsGrid) websites.Add("solidjobs");

        model = new DataModel
        {
            websites = websites,
            phrase = searchedKeyword,
            request_number = "30",
            additional_phrase = "",
            work_location = string.IsNullOrWhiteSpace(workLocation) ? null : workLocation.Trim(),
            employment_level = employmentLevel,
            contract_type = contractType,
        };

        try
        {
            var result = await DataProxy.getData(model);
            if (result == null || !result.Success)
            {
                await DialogService.Alert(result?.Message ?? Loc["ErrorFetching"].Value);
                return;
            }
            pracujData = result.Data?.PracujData?.Output;
            jjiData = result.Data?.JustjoinitData?.Output;
            nfjData = result.Data?.NofluffjobsData?.Output;
            tpData = result.Data?.TheprotocolitData?.Output;
            bulldogData = result.Data?.BulldogjobData?.Output;
            solidJobsData = result.Data?.SolidjobsData?.Output;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"{Loc["ErrorFetching"]} {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
