@page "/cars"

@using WyszukiwaczAppDTO
@using System.Threading.Tasks
@inject DataProxy DataProxy
@inject DialogService DialogService

<style>
    .link {
        background-color: #a04ba7;
        border: none;
        color: white;
        padding: 6px 19px;
        text-decoration: none;
        display: inline-block;
        border: 1px solid #7c658b;
        cursor: pointer;
        border-radius: 12px;
        transition: background-color 0.3s, transform 0.3s;
    }

    .link:hover {
        color: #7c658b;
        text-decoration: none !important;
        background-color: white;
        border: 2px solid #7c658b;
    }

    .link:active {
        box-shadow: none;
        color: white;
        text-decoration: none !important;
    }

    .rz-form-field-content {
        outline: none !important;
        border-radius: 15px;
    }

    .grid-margin {
        margin-bottom: 20px;
        box-shadow: 0 0 50px #ccc;
    }
</style>

<RadzenRow AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="1rem" Class="rz-p-sm-12">
    <RadzenColumn Size="12" SizeMD="12" SizeLG="12">
        <RadzenFormField Text="Marka" Variant="Variant.Flat" Style="width:49%;">
            <RadzenTextBox @bind-Value="@searchedBrand" Style="width: 49%; border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="Model" Variant="Variant.Flat" Style="width:50%">
            <RadzenTextBox @bind-Value="@searchedModel" Style="width: 50%; border-radius:15px;" />
        </RadzenFormField>
        <RadzenDropDown TValue="string"
                        @bind-Value="@selectedFuelType"
                        Data="@fuelTypes"
                        TextProperty="DisplayText"
                        ValueProperty="Value"
                        Placeholder="Wybierz rodzaj paliwa"
                        Style="width: 300px"
                        Name="FuelType" />
        <RadzenDropDown TValue="int?"
                        @bind-Value="@selectedHorsepower"
                        Data="@horsepowerValues"
                        Placeholder="Wybierz moc silnika (KM)"
                        Style="width: 300px"
                        Name="Horsepower" />
        <RadzenDropDown TValue="int?"
                        @bind-Value="@selectedCapacity"
                        Data="@capacityValues"
                        Placeholder="Wybierz pojemność silnika (cm³)"
                        Style="width: 300px"
                        Name="EngineCapacity" />
        <RadzenFormField Variant="Variant.Flat" Style="width: 150px; border-radius:15px !important;">
            <RadzenButton Click=LoadData Text="ZAŁADUJ" Icon="cached" ButtonStyle="ButtonStyle.Success" Shade="Shade.Darker" Style="height:3.25rem; border-radius:15px;" Disabled="@string.IsNullOrWhiteSpace(SearchPhrase)" />
        </RadzenFormField>
    </RadzenColumn>
</RadzenRow>

<RadzenText TextStyle="TextStyle.H4" Text="Wybierz strony, z których chcesz pobrać ogłoszenia" Style="color:red; margin-bottom:20px;" />

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter">
    <RadzenImage Path="images/olx.png" Style="width: 2rem;height:2rem;" AlternateText="OLX" />
    <RadzenLabel Text="Olx" Component="CheckBox2" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setOlxGrid Name="CheckBox2" />
</RadzenButton>

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter">
    <RadzenImage Path="images/sprzedajemy.jpg" Style="width: 4rem;height:2rem;" AlternateText="Sprzedajemy" />
    <RadzenLabel Text="Sprzedajemy" Component="CheckBox6" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setSprzedajemyGrid Name="CheckBox6" />
</RadzenButton>
<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter">
    <RadzenImage Path="images/otomoto.gif" Style="width: 3rem;height:2rem;" AlternateText="OTOMOTO" />
    <RadzenLabel Text="OtoMoto" Component="CheckBox1" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setOtomotoGrid Name="CheckBox1" />
</RadzenButton>
<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter">
    <RadzenImage Path="images/gratka.png" Style="width: 2rem;height:2rem;" AlternateText="Gratka" />
    <RadzenLabel Text="Gratka" Component="CheckBox4" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setGratkaGrid Name="CheckBox4" />
</RadzenButton>
<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter">
    <RadzenImage Path="images/autoscout.png" Style="width: 2rem;height:2rem;" AlternateText="Autoscout" />
    <RadzenLabel Text="Autoscout" Component="CheckBox3" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setAutoscoutGrid Name="CheckBox3" />
</RadzenButton>
<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter" Style="margin-bottom:30px;">
    <RadzenImage Path="images/autocentrum.png" Style="width: 2rem;height:2rem;" AlternateText="Autocentrum" />
    <RadzenLabel Text="Autocentrum" Component="CheckBox5" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setAutocentrumGrid Name="CheckBox5" />
</RadzenButton>

@if (setOlxGrid)
{

    <RadzenDataGrid Data="@olxData" style="--rz-grid-header-text-transform: none; --rz-grid-header-font-size: 1rem;"
                    AllowFiltering="true" AllowColumnResize="true" AllowAlternatingRows="false" AllowColumnReorder="true"
                    FilterMode="FilterMode.Advanced" AllowSorting="true" PageSize="10" AllowPaging="true"
                    PagerHorizontalAlign="HorizontalAlign.Center" FilterPopupRenderMode="PopupRenderMode.OnDemand"
                    class="grid-margin" IsLoading="isLoading" ShowPagingSummary="true"
                    LogicalFilterOperator="LogicalFilterOperator.Or" SelectionMode="DataGridSelectionMode.Single">
        <EmptyTemplate>
            <p style="color: lightgrey; font-size: 24px; text-align: center; margin: 2rem;">Brak danych do wyświetlenia.</p>
        </EmptyTemplate>
        <HeaderTemplate>
            <RadzenImage Path="images/olx.png" Style="width: 4rem; height:4rem;" AlternateText="Olx" />
            <h3 style="display: inline-block; margin-left:10px; color:red;font-weight:bold;">Olx</h3>
        </HeaderTemplate>
        <Columns>
            <RadzenDataGridColumn Property="Title" Title="Tytuł" Frozen="true" Width="300px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText TextStyle="TextStyle.H6" style="font-weight:bold; white-space:pre-wrap">@context.Title</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Url" Title="Link" Width="150px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <div class="rz-text-align-center" style="height:38px;">
                        <RadzenLink Path="@context.Url" Text="Otwórz Link" Target="_blank" class="link" />
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Price" Title="Cena (PLN)" TextAlign="TextAlign.Center">
                <Template Context="context">@((int?)context.Price)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Location" Title="Lokalizacja" TextAlign="TextAlign.Center">
                <Template Context="context">
                    @(context.Location?.Contains(" - ") == true ? context.Location.Substring(0, context.Location.IndexOf(" - ")) : context.Location)
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="Location" Title="Data dodania" TextAlign="TextAlign.Center">
                <Template Context="context">
                    @(context.Location?.Contains(" - ") == true ? context.Location.Substring(context.Location.IndexOf(" - ") + 3) : "")
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="VehicleDetail.Mileage" Title="Przebieg (km)" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="context">@context.VehicleDetail?.Mileage</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="VehicleDetail.ProductionYear" Title="Rok produkcji" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="context">@context.VehicleDetail?.ProductionYear</Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

