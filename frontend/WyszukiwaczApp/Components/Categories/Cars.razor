                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="ImageUrl" Title="@(Loc["Image"].Value)" Sortable="false" Filterable="false" Width="120px" TextAlign="TextAlign.Center">
                <Template Context="context">
                    @if (string.IsNullOrEmpty(context.ImageUrl))
                    {
                        <div style="color: gray; text-align: center; font-style: italic;">@Loc["NoImage"]</div>
                    }
                    else
                    {
                        <RadzenImage Path="@context.ImageUrl" Style="width:4rem;height:4rem;" AlternateText="@(Loc["Image"].Value)" />
