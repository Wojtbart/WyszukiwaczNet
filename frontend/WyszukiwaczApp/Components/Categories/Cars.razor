                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="SellerName" Title="@(Loc["Seller"].Value)" TextAlign="TextAlign.Center" />
            <RadzenDataGridColumn Property="VehicleDetail.Mileage" Title="@(Loc["MileageKm"].Value)" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="context">@context.VehicleDetail?.Mileage</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="VehicleDetail.ProductionYear" Title="@(Loc["ProductionYear"].Value)" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="context">@context.VehicleDetail?.ProductionYear</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="VehicleDetail.FuelType" Title="@(Loc["Fuel"].Value)" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="context">@context.VehicleDetail?.FuelType</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="VehicleDetail.Gearbox" Title="@(Loc["Gearbox"].Value)" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="context">@context.VehicleDetail?.Gearbox</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="AdditionalInfo" Title="@(Loc["Extra"].Value)" TextAlign="TextAlign.Center">
                <Template Context="context">
                    <RadzenText style="white-space:pre-wrap">@context.AdditionalInfo</RadzenText>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private string searchedBrand = string.Empty;
    private string searchedModel = string.Empty;

    private string SearchPhrase => $"{searchedBrand} {searchedModel}".Trim();

    private bool isLoading = false;
    private bool setOtomotoGrid = false;
    private bool setOlxGrid = false;
    private bool setAutoscoutGrid = false;
    private bool setGratkaGrid = false;
    private bool setSprzedajemyGrid = false;
    private bool setAutocentrumGrid = false;
    private bool setSamochodyGrid = false;

    private IEnumerable<ScrapedItem>? otoMotoData;
    private IEnumerable<ScrapedItem>? olxData;
    private IEnumerable<ScrapedItem>? autoscoutData;
    private IEnumerable<ScrapedItem>? gratkaData;
    private IEnumerable<ScrapedItem>? sprzedajemyData;
    private IEnumerable<ScrapedItem>? autocentrumData;
    private IEnumerable<ScrapedItem>? samochodyData;

    private List<FilterOption> fuelTypes => new()
    {
        new FilterOption { DisplayText = Loc["FuelPetrol"],   Value = "petrol" },
        new FilterOption { DisplayText = Loc["FuelLpg"],      Value = "lpg" },
        new FilterOption { DisplayText = Loc["FuelDiesel"],   Value = "diesel" },
        new FilterOption { DisplayText = Loc["FuelElectric"], Value = "electric" },
        new FilterOption { DisplayText = Loc["FuelHybrid"],   Value = "plugin-hybrid" }
    };

    private List<FilterOption> gearboxTypes => new()
    {
        new FilterOption { DisplayText = Loc["GearboxManual"],    Value = "manual" },
        new FilterOption { DisplayText = Loc["GearboxAutomatic"], Value = "automatic" }
    };

    private string? selectedFuelType;
    private string? selectedGearbox;
    private int? selectedEngineCapacityFrom;
    private int? selectedEngineCapacityTo;
    private decimal? selectedPriceFrom;
    private decimal? selectedPriceTo;

    public class FilterOption
    {
        public string DisplayText { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private void SelectAll()
    {
        setOlxGrid = setSprzedajemyGrid = setOtomotoGrid = setGratkaGrid = setAutocentrumGrid = setSamochodyGrid = true;
    }

    private void DeselectAll()
    {
        setOlxGrid = setSprzedajemyGrid = setOtomotoGrid = setGratkaGrid = setAutocentrumGrid = setSamochodyGrid = false;
    }

    DataModel model = new();

    private async Task LoadData()
    {
        if (string.IsNullOrWhiteSpace(SearchPhrase))
        {
            await DialogService.Alert(Loc["FillBrandOrModel"]);
            return;
        }
        if (!Globals.IsPhraseValid(SearchPhrase))
        {
            await DialogService.Alert(Loc["InvalidPhrase"]);
            return;
        }

        isLoading = true;

        var websites = new List<string>();
        if (setOtomotoGrid)    websites.Add("otoMoto");
        if (setOlxGrid)        websites.Add("olx");
        if (setAutoscoutGrid)  websites.Add("autoscout");
        if (setGratkaGrid)     websites.Add("gratka");
        if (setSprzedajemyGrid) websites.Add("sprzedajemy");
        if (setAutocentrumGrid) websites.Add("autocentrum");
        if (setSamochodyGrid)   websites.Add("samochody");

        model = new DataModel
        {
            websites = websites,
            phrase = SearchPhrase,
            request_number = "30",
            fuel = string.IsNullOrEmpty(selectedFuelType) ? null : selectedFuelType,
            gearbox = string.IsNullOrEmpty(selectedGearbox) ? null : selectedGearbox,
            engine_capacity_from = selectedEngineCapacityFrom,
            engine_capacity_to = selectedEngineCapacityTo,
            price_from = selectedPriceFrom,
            price_to = selectedPriceTo,
        };

        try
        {
            var result = await DataProxy.getData(model);

            otoMotoData  = result?.Data?.OtoMotoData?.Output;
            olxData      = result?.Data?.OlxData?.Output;
            autoscoutData   = result?.Data?.AutoscoutData?.Output;
            gratkaData      = result?.Data?.GratkaData?.Output;
            sprzedajemyData = result?.Data?.SprzedajemyData?.Output;
            autocentrumData = result?.Data?.AutocentrumData?.Output;
            samochodyData   = result?.Data?.SamochodyData?.Output;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"{Loc["ErrorFetching"]} {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
