            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="VehicleDetail.BodyType" Title="Typ nadwozia" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="context">
                    @{
                        var bt = context.VehicleDetail?.BodyType;
                        var colon = bt?.IndexOf(": ") ?? -1;
