@page "/cars"

@using WyszukiwaczAppDTO
@using System.Threading.Tasks
@inject DataProxy DataProxy
@inject DialogService DialogService
@inject IStringLocalizer<SharedResource> Loc

<style>
    .link {
        background-color: #a04ba7;
        border: none;
        color: white;
        padding: 6px 19px;
        text-decoration: none !important;
        display: inline-block;
        border: 1px solid #7c658b;
        cursor: pointer;
        border-radius: 12px;
        transition: background-color 0.3s, transform 0.3s;
    }

    .link:hover, .link:visited {
        color: #7c658b;
        text-decoration: none !important;
        background-color: white;
        border: 2px solid #7c658b;
    }

    .link:active {
        box-shadow: none;
        color: white;
        text-decoration: none !important;
    }

    .rz-form-field-content {
        outline: none !important;
        border-radius: 15px;
    }

    .grid-margin {
        margin-bottom: 20px;
        box-shadow: 0 0 50px #ccc;
    }
</style>

<RadzenRow AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="1rem" Class="rz-p-sm-12">
    <RadzenColumn Size="12" SizeMD="12" SizeLG="12">
        <RadzenFormField Text="@(Loc["Brand"].Value)" Variant="Variant.Flat" Style="width:49%;">
            <RadzenTextBox @bind-Value="@searchedBrand" Style="width: 49%; border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="@(Loc["Model"].Value)" Variant="Variant.Flat" Style="width:50%">
            <RadzenTextBox @bind-Value="@searchedModel" Style="width: 50%; border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Variant="Variant.Flat" Style="width: 300px;">
            <RadzenDropDown TValue="string?"
                            @bind-Value="@selectedFuelType"
                            Data="@fuelTypes"
                            TextProperty="DisplayText"
                            ValueProperty="Value"
                            Placeholder="@(Loc["ChooseFuel"].Value)"
                            AllowClear="true"
                            Style="width: 100%;"
                            Name="FuelType" />
        </RadzenFormField>
        <RadzenFormField Variant="Variant.Flat" Style="width: 250px;">
            <RadzenDropDown TValue="string?"
                            @bind-Value="@selectedGearbox"
                            Data="@gearboxTypes"
                            TextProperty="DisplayText"
                            ValueProperty="Value"
                            Placeholder="@(Loc["ChooseGearbox"].Value)"
                            AllowClear="true"
                            Style="width: 100%; border-radius:15px;"
                            Name="Gearbox" />
        </RadzenFormField>
        <RadzenFormField Text="@(Loc["CapacityFrom"].Value)" Variant="Variant.Flat" Style="width: 155px;">
            <RadzenNumeric @bind-Value="@selectedEngineCapacityFrom" TValue="int?" Style="border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="@(Loc["CapacityTo"].Value)" Variant="Variant.Flat" Style="width: 155px;">
            <RadzenNumeric @bind-Value="@selectedEngineCapacityTo" TValue="int?" Style="border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="@(Loc["PriceFrom"].Value)" Variant="Variant.Flat" Style="width: 155px;">
            <RadzenNumeric @bind-Value="@selectedPriceFrom" TValue="decimal?" Style="border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Text="@(Loc["PriceTo"].Value)" Variant="Variant.Flat" Style="width: 155px;">
            <RadzenNumeric @bind-Value="@selectedPriceTo" TValue="decimal?" Style="border-radius:15px;" />
        </RadzenFormField>
        <RadzenFormField Variant="Variant.Flat" Style="width: 150px; border-radius:15px !important;">
            <RadzenButton Click=LoadData Text="@(Loc["Load"].Value)" Icon="cached" ButtonStyle="ButtonStyle.Success" Shade="Shade.Darker" Style="height:3.25rem; border-radius:15px;" Disabled="@string.IsNullOrWhiteSpace(SearchPhrase)" />
        </RadzenFormField>
        <a href="/notification_settings?category=Motoryzacja" style="display:inline-flex; align-items:center; gap:0.4rem; padding:0 1.2rem; height:3.25rem; background:#a04ba7; color:white; text-decoration:none; border-radius:15px; font-size:0.875rem; font-weight:600; border:1px solid #7c658b; cursor:pointer; white-space:nowrap; transition:background 0.2s; vertical-align:middle; margin-left:0.5rem;">
            🔔 @Loc["SetRecurringNotifications"]
        </a>
    </RadzenColumn>
</RadzenRow>

<RadzenText TextStyle="TextStyle.H4" Text="@(Loc["ChoosePagesAds"].Value)" Style="color:red; margin-bottom:20px;" />

<RadzenButton Text="@(Loc["SelectAll"].Value)" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Style="margin-bottom:8px; margin-right:8px;" Click="SelectAll" />
<RadzenButton Text="@(Loc["DeselectAll"].Value)" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Style="margin-bottom:8px; margin-right:8px;" Click="DeselectAll" />

<RadzenButton Icon="cached" ButtonStyle="ButtonStyle.Light" Shade="Shade.Lighter">
    <RadzenImage Path="images/olx.png" Style="width: 2rem;height:2rem;" AlternateText="OLX" />
    <RadzenLabel Text="Olx" Component="CheckBox2" Style="margin:0.3rem; vertical-align: middle;" />
    <RadzenCheckBox @bind-Value=@setOlxGrid Name="CheckBox2" />
