<style>
    .link {
        background-color: #a04ba7;
        border: none;
        color: white;
        padding: 6px 19px;
        text-decoration: none;
        display: inline-block;
        border: 1px solid #7c658b;
        cursor: pointer;
        border-radius: 12px;
        transition: background-color 0.3s, transform 0.3s;
    }

    .link:hover {
        color: #7c658b;
        text-decoration: none !important;
        background-color: white;
        border: 2px solid #7c658b;
    }

    .link:active {
        box-shadow: none;
        color: white;
        text-decoration: none !important;
    }

    .grid-margin {
        margin-bottom: 20px;
        box-shadow: 0 0 50px #ccc;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #666;
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .section-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #888;
        margin: 1rem 0 0.4rem;
    }

    .section-label:first-of-type {
        margin-top: 0;
    }

    .platform-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 0.5rem;
    }
</style>

