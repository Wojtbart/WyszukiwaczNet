@inject NavigationManager Navigation
@page "/categories"

<style>
    .categories-container {
        padding: 2rem;
        max-width: 800px;
        margin: 0 auto;
        text-align: center;
    }

    .categories-container h2 {
        margin-bottom: 1.5rem;
        color: #333;
    }

    .category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
    }

    .category-card {
        background: white;
        padding: 1.5rem;
        border-radius: 12px;
        text-align: center;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.2s;
        text-decoration: none;
        color: #333;
    }

    .category-card:hover {
        border-color: #667eea;
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
        text-decoration: none;
        color: #333;
    }

    .category-icon {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }
</style>

<div class="categories-container">
    <h2>Kategorie</h2>
    <div class="category-grid">
        <a href="/cars" class="category-card">
            <div class="category-icon">🚗</div>
            <div>Samochody</div>
        </a>
        <a href="/flats" class="category-card">
            <div class="category-icon">🏠</div>
            <div>Mieszkania</div>
        </a>
        <a href="/shopping" class="category-card">
            <div class="category-icon">🛒</div>
            <div>Zakupy</div>
        </a>
    </div>
</div>

@code {
}
