@page "/notification_settings"
@using WyszukiwaczAppDTO
@using WyszukiwaczApp.Proxies
@using WyszukiwaczApp.Services

@inject NotificationService NotificationService
@inject NavigationManager Navigation
@inject NotificationProxy NotificationProxy
@inject LoginProxy LoginProxy
@inject UserService UserService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IStringLocalizer<SharedResource> Loc

<div class="notif-page">

    <!-- Header -->
    <div class="notif-header">
        <div class="notif-header-icon">
            <RadzenIcon Icon="notifications_active" />
        </div>
        <div>
            <h1 class="notif-title">@Loc["Notifications"]</h1>
            <p class="notif-subtitle">@Loc["ConfigureNotifications"]</p>
        </div>
    </div>

    <!-- ACTIVE JOBS — top section -->
    <div class="notif-jobs-top">
        <div class="notif-jobs-top-header">
            <div style="display:flex;align-items:center;gap:0.5rem;">
                <RadzenIcon Icon="work_history" style="color:#007bff;" />
                <span class="notif-jobs-top-title">@Loc["ActiveJobs"]</span>
                @if (userJobs != null)
                {
                    <span class="jobs-count-badge">@userJobs.Count</span>
                }
            </div>
            <RadzenButton Click="LoadJobs" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small" />
        </div>

        @if (userJobs == null)
        {
            <span class="jobs-loading">@Loc["Loading"]</span>
        }
        else if (!userJobs.Any())
        {
            <div class="jobs-empty">
                <RadzenIcon Icon="check_circle" style="font-size:2rem;color:#d1d5db;" />
                <span>@Loc["NoActiveJobs"]</span>
            </div>
        }
        else
        {
            <div class="jobs-grid">
                @foreach (var job in userJobs)
                {
                    var (stateLabel, stateCss) = StateDisplay(job.LastState);
                    <div class="job-card-top">
                        <div class="job-card-header">
                            <span class="job-card-phrase">@(string.IsNullOrWhiteSpace(job.Phrase) ? "—" : job.Phrase)</span>
                            <span class="job-state @stateCss">@stateLabel</span>
                        </div>
                        <div class="job-card-rows">
                            <div class="job-card-row">
                                <span class="job-card-label">⏱ Harmonogram</span>
                                <span class="job-card-value">@CronToHuman(job.Cron)</span>
                            </div>
                            @if (job.NextExecution.HasValue)
                            {
                                <div class="job-card-row">
                                    <span class="job-card-label">→ Następne</span>
                                    <span class="job-card-value job-card-value--next">@job.NextExecution.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                            }
                            @if (job.LastExecution.HasValue)
                            {
                                <div class="job-card-row">
                                    <span class="job-card-label">✓ Ostatnie</span>
                                    <span class="job-card-value job-card-value--last">@job.LastExecution.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="notif-grid">

        <!-- LEFT COLUMN -->
        <div class="notif-col-main">

            <!-- Category selector card -->
            <div class="n-card">
                <div class="n-card-header">
                    <RadzenIcon Icon="category" class="n-card-icon" />
                    <span>@Loc["Category"]</span>
                </div>
                <div class="n-card-body">
                    <div class="cat-selector">
                        <div class="cat-btn @(_selectedCategory == "Motoryzacja" ? "cat-btn--active" : "")"
                             @onclick='async () => await SelectCategory("Motoryzacja")'>
                            <span class="cat-btn-emoji">🚗</span>
                            <span>@Loc["CatAuto"]</span>
                            <span class="cat-status @(_categoryEnabled.GetValueOrDefault("Motoryzacja") ? "cat-status--on" : "cat-status--off")">
                                @(_categoryEnabled.GetValueOrDefault("Motoryzacja") ? Loc["Active"] : Loc["Inactive"])
                            </span>
                        </div>
                        <div class="cat-btn @(_selectedCategory == "Nieruchomości" ? "cat-btn--active" : "")"
                             @onclick='async () => await SelectCategory("Nieruchomości")'>
                            <span class="cat-btn-emoji">🏠</span>
                            <span>@Loc["CatRealEstate"]</span>
                            <span class="cat-status @(_categoryEnabled.GetValueOrDefault("Nieruchomości") ? "cat-status--on" : "cat-status--off")">
                                @(_categoryEnabled.GetValueOrDefault("Nieruchomości") ? Loc["Active"] : Loc["Inactive"])
                            </span>
                        </div>
                        <div class="cat-btn @(_selectedCategory == "Zakupy" ? "cat-btn--active" : "")"
                             @onclick='async () => await SelectCategory("Zakupy")'>
                            <span class="cat-btn-emoji">🛒</span>
                            <span>@Loc["CatShopping"]</span>
                            <span class="cat-status @(_categoryEnabled.GetValueOrDefault("Zakupy") ? "cat-status--on" : "cat-status--off")">
                                @(_categoryEnabled.GetValueOrDefault("Zakupy") ? Loc["Active"] : Loc["Inactive"])
                            </span>
                        </div>
                        <div class="cat-btn @(_selectedCategory == "Praca" ? "cat-btn--active" : "")"
                             @onclick='async () => await SelectCategory("Praca")'>
                            <span class="cat-btn-emoji">💼</span>
                            <span>@Loc["CatWork"]</span>
                            <span class="cat-status @(_categoryEnabled.GetValueOrDefault("Praca") ? "cat-status--on" : "cat-status--off")">
                                @(_categoryEnabled.GetValueOrDefault("Praca") ? Loc["Active"] : Loc["Inactive"])
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_selectedCategory))
            {
            <!-- Search card -->
            <div class="n-card">
                <div class="n-card-header">
                    <RadzenIcon Icon="search" class="n-card-icon" />
                    <span>@Loc["Search"]</span>
                </div>
                <div class="n-card-body">
                    <div class="n-field">
                        <label class="n-label">@Loc["SearchedText"]</label>
                        <RadzenTextBox @bind-Value="@searchedText" Placeholder="@SearchPlaceholder" class="n-input-full" />
                    </div>
                    <div class="n-field">
                        <label class="n-label">@Loc["MaxResults"]</label>
                        <RadzenNumeric Min="1" Max="30" @bind-Value="@requestNumbers" class="n-input-sm" />
                    </div>
                </div>
            </div>

            <!-- Platforms card -->
            <div class="n-card">
                <div class="n-card-header">
                    <RadzenIcon Icon="language" class="n-card-icon" />
                    <span>@Loc["Platforms"] – @LocalizedCategory(_selectedCategory)</span>
                </div>
                <div class="n-card-body">
                    <div class="platform-grid">
                        @foreach (var platform in ActivePlatforms)
                        {
                            var isSelected = selectedPlatforms.Contains(platform);
                            <div class="platform-chip @(isSelected ? "platform-chip--active" : "")"
                                 @onclick="() => TogglePlatform(platform)">
                                <RadzenIcon Icon="@(isSelected ? "check_circle" : "radio_button_unchecked")" class="platform-chip-icon" />
                                @platform
                            </div>
                        }
                    </div>
                </div>
            </div>
            }

            <!-- Notification channels card -->
            <div class="n-card">
                <div class="n-card-header">
                    <RadzenIcon Icon="send" class="n-card-icon" />
                    <span>@Loc["NotificationChannels"]</span>
                </div>
                <div class="n-card-body">
                    <div class="channel-list">
                        <div class="channel-item @(isEmailChecked ? "channel-item--active" : "")">
                            <div class="channel-icon channel-icon--email">
                                <RadzenIcon Icon="email" />
                            </div>
                            <div class="channel-info">
                                <span class="channel-name">@Loc["Email"]</span>
                                <span class="channel-desc">@Loc["EmailDesc"]</span>
                            </div>
                            <RadzenCheckBox TValue="bool" @bind-Value="isEmailChecked" class="channel-toggle" />
                        </div>
                        <div class="channel-item @(isSMSChecked ? "channel-item--active" : "")">
                            <div class="channel-icon channel-icon--sms">
                                <RadzenIcon Icon="sms" />
                            </div>
                            <div class="channel-info">
                                <span class="channel-name">@Loc["SMS"]</span>
                                <span class="channel-desc">@Loc["SMSDesc"]</span>
                            </div>
                            <RadzenCheckBox TValue="bool" @bind-Value="isSMSChecked" class="channel-toggle" />
                        </div>
                        <div class="channel-item @(isDiscordChecked ? "channel-item--active" : "")">
                            <div class="channel-icon channel-icon--discord">
                                <RadzenIcon Icon="forum" />
                            </div>
                            <div class="channel-info">
                                <span class="channel-name">@Loc["Discord"]</span>
                                <span class="channel-desc">@Loc["DiscordDesc"]</span>
                            </div>
                            <RadzenCheckBox TValue="bool" @bind-Value="isDiscordChecked" class="channel-toggle" />
                        </div>
                        <div class="channel-item @(isInAppChecked ? "channel-item--active" : "")">
                            <div class="channel-icon channel-icon--inapp">
                                <RadzenIcon Icon="notifications" />
                            </div>
                            <div class="channel-info">
                                <span class="channel-name">@Loc["InApp"]</span>
                                <span class="channel-desc">@Loc["InAppDesc"]</span>
                            </div>
                            <RadzenCheckBox TValue="bool" @bind-Value="isInAppChecked" class="channel-toggle" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Schedule card -->
            <div class="n-card">
                <div class="n-card-header">
                    <RadzenIcon Icon="schedule" class="n-card-icon" />
                    <span>@Loc["Schedule"]</span>
                </div>
                <div class="n-card-body">
                    <div class="schedule-option @(isSendingHourChecked ? "schedule-option--active" : "")">
                        <div class="schedule-option-header">
                            <div>
                                <span class="schedule-option-title">@Loc["SendAtHour"]</span>
                                <span class="schedule-option-desc">@Loc["SendAtHourDesc"]</span>
                            </div>
                            <RadzenCheckBox TValue="bool" @bind-Value="isSendingHourChecked" Change="OnCheckboxHourChanged" />
                        </div>
                        @if (isSendingHourChecked)
                        {
                            <div class="schedule-picker">
                                <RadzenDatePicker @bind-Value="@dateSendingNotification"
                                                  ShowTime="true" TimeOnly="true" DateFormat="HH:mm"
                                                  Style="width: 140px;" />
                            </div>
                        }
                    </div>
                    <div class="schedule-option @(isCyclicMessagingChecked ? "schedule-option--active" : "")">
                        <div class="schedule-option-header">
                            <div>
                                <span class="schedule-option-title">@Loc["Cyclic"]</span>
                                <span class="schedule-option-desc">@Loc["CyclicDesc"]</span>
                            </div>
                            <RadzenCheckBox TValue="bool" @bind-Value="isCyclicMessagingChecked" Change="OnCheckboxCyclicChanged" />
                        </div>
                        @if (isCyclicMessagingChecked)
                        {
                            <div class="schedule-picker">
                                <label class="n-label">@Loc["EveryHowManyMin"]</label>
                                <RadzenNumeric Min="1" Max="100" @bind-Value="@minutesAfterSendingNotification" Style="width: 100px;" />
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (_selectedCategory == "Nieruchomości")
            {
            <!-- Apartment filters card -->
            <div class="n-card">
                <div class="n-card-header">
                    <RadzenIcon Icon="apartment" class="n-card-icon" />
                    <span>@Loc["FiltersRealEstate"]</span>
                </div>
                <div class="n-card-body">
                    <div class="filter-grid">
                        <label class="filter-chip @(isSprzedaz ? "filter-chip--active" : "")">
                            <input type="checkbox" @bind="isSprzedaz" @bind:after="() => OnCheckboxChanged(isSprzedaz)" hidden />
                            @Loc["Sale"]
                        </label>
                        <label class="filter-chip @(isWynajem ? "filter-chip--active" : "")">
                            <input type="checkbox" @bind="isWynajem" @bind:after="() => OnCheckboxChanged(isWynajem)" hidden />
                            @Loc["Rent"]
                        </label>
                        <label class="filter-chip @(isPrywatne ? "filter-chip--active" : "")">
                            <input type="checkbox" @bind="isPrywatne" @bind:after="() => OnCheckboxChanged(isPrywatne)" hidden />
                            @Loc["Private"]
                        </label>
                        <label class="filter-chip @(isPubliczne ? "filter-chip--active" : "")">
                            <input type="checkbox" @bind="isPubliczne" @bind:after="() => OnCheckboxChanged(isPubliczne)" hidden />
                            @Loc["Public"]
                        </label>
                        <label class="filter-chip @(isOstatnie24h ? "filter-chip--active" : "")">
                            <input type="checkbox" @bind="isOstatnie24h" @bind:after="() => OnCheckboxChanged(isOstatnie24h)" hidden />
                            @Loc["Last24h"]
                        </label>
                        <label class="filter-chip @(isDowolna ? "filter-chip--active" : "")">
                            <input type="checkbox" @bind="isDowolna" @bind:after="() => OnCheckboxChanged(isDowolna)" hidden />
                            @Loc["AnyF"]
                        </label>
                    </div>
                </div>
            </div>
            }

        </div>

        <!-- RIGHT COLUMN — summary -->
        <div class="notif-col-side">
            <div class="n-card n-summary">
                <div class="n-card-header">
                    <RadzenIcon Icon="summarize" class="n-card-icon" />
                    <span>@Loc["Summary"]</span>
                </div>
                <div class="n-card-body">

                    <div class="summary-section">
                        <span class="summary-label">@Loc["Category"]</span>
                        <span class="summary-value">@(string.IsNullOrEmpty(_selectedCategory) ? "—" : LocalizedCategory(_selectedCategory))</span>
                    </div>

                    <div class="summary-section">
                        <span class="summary-label">@Loc["Phrase"]</span>
                        <span class="summary-value">@(string.IsNullOrEmpty(searchedText) ? "—" : searchedText)</span>
                    </div>

                    <div class="summary-section">
                        <span class="summary-label">@Loc["MaxResultsShort"]</span>
                        <span class="summary-value">@(requestNumbers > 0 ? requestNumbers.ToString() : "—")</span>
                    </div>

                    <div class="summary-section">
                        <span class="summary-label">@Loc["Schedule"]</span>
                        <span class="summary-value">
                            @if (isSendingHourChecked && dateSendingNotification.HasValue)
                            { @($"{Loc["DailyAt"]} {dateSendingNotification:HH:mm}") }
                            else if (isCyclicMessagingChecked && minutesAfterSendingNotification > 0)
                            { @($"{Loc["Every"]} {minutesAfterSendingNotification} {Loc["Min"]}") }
                            else
                            { <span class="summary-empty">@Loc["NotSet"]</span> }
                        </span>
                    </div>

                    <div class="summary-section">
                        <span class="summary-label">@Loc["Channels"]</span>
                        <div class="summary-chips">
                            @if (isEmailChecked) { <span class="s-chip s-chip--email">@Loc["Email"]</span> }
                            @if (isSMSChecked)   { <span class="s-chip s-chip--sms">@Loc["SMS"]</span> }
                            @if (isDiscordChecked) { <span class="s-chip s-chip--discord">@Loc["Discord"]</span> }
                            @if (isInAppChecked) { <span class="s-chip s-chip--inapp">@Loc["InAppChip"]</span> }
                            @if (!isEmailChecked && !isSMSChecked && !isDiscordChecked && !isInAppChecked)
                            { <span class="summary-empty">@Loc["None"]</span> }
                        </div>
                    </div>

                    <div class="summary-section">
                        <span class="summary-label">@Loc["Platforms"]</span>
                        <div class="summary-chips">
                            @foreach (var p in selectedPlatforms)
                            { <span class="s-chip s-chip--platform">@p</span> }
                            @if (!selectedPlatforms.Any())
                            { <span class="summary-empty">@Loc["None"]</span> }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action buttons -->
            <div class="notif-actions">
                <RadzenButton Click="SaveConfiguration" Icon="save" Text="@(Loc["SaveSettings"].Value)"
                              ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large"
                              class="n-btn-full" />
                <RadzenButton Click="DeleteJobs" Icon="delete_forever" Text="@(Loc["DeleteScheduledJobs"].Value)"
                              ButtonStyle="ButtonStyle.Danger" Shade="Shade.Lighter" Size="ButtonSize.Medium"
                              class="n-btn-full" />
            </div>

        </div>

    </div>
</div>

@code {
    private object formData = new();
    private List<UserJobDto>? userJobs;

    private int userId;
    private int _emailChannelId;
    private int _smsChannelId;
    private int _discordChannelId;
    private int _inAppChannelId;

    private List<UserNotificationSettingDto> notificationChannels = new();
    private List<UserPlatformSubscriptionDto> platformSubscriptions = new();
    private List<NotificationChannel> allChannels = new();
    private List<PlatformResponse> allPlatforms = new();

    private bool isSMSChecked = false;
    private bool isDiscordChecked = false;
    private bool isEmailChecked = false;
    private bool isInAppChecked = false;

    private bool setSendingHourPreview = true;
    private bool repeatRequestAfterTimePreview = true;
    private bool isSendingHourChecked = false;
    private bool isCyclicMessagingChecked = false;
    private int minutesAfterSendingNotification;

    private bool isSprzedaz;
    private bool isWynajem;
    private bool isPrywatne;
    private bool isPubliczne;
    private bool isOstatnie24h;
    private bool isDowolna;

    private string additional_phrase = string.Empty;

    private string _selectedCategory = string.Empty;
    private Dictionary<string, bool> _categoryEnabled = new();
    private List<string> _carPlatforms  = new() { "OtoMoto", "Olx", "Gratka", "Sprzedajemy", "Autocentrum", "Samochody" };
    private List<string> _flatPlatforms = new() { "OtoDom" };
    private List<string> _shopPlatforms = new() { "Amazon", "Olx" };
    private List<string> _workPlatforms = new() { "Pracuj", "JustJoinIt", "NoFluffJobs", "TheProtocolIt", "BulldogJob" };
    private List<string> availablePlatforms => _carPlatforms.Concat(_flatPlatforms).Concat(_shopPlatforms).Concat(_workPlatforms).ToList();
    private List<string> ActivePlatforms => _selectedCategory switch
    {
        "Motoryzacja"   => _carPlatforms,
        "Nieruchomości" => _flatPlatforms,
        "Zakupy"        => _shopPlatforms,
        "Praca"         => _workPlatforms,
        _               => new()
    };
    private string SearchPlaceholder => _selectedCategory switch
    {
        "Motoryzacja"   => Loc["PlaceholderAuto"],
        "Nieruchomości" => Loc["PlaceholderRealEstate"],
        "Zakupy"        => Loc["PlaceholderShopping"],
        "Praca"         => Loc["PlaceholderWork"],
        _               => Loc["PlaceholderDefault"]
    };

    private string LocalizedCategory(string? cat) => cat switch
    {
        "Motoryzacja"   => Loc["CatAuto"],
        "Nieruchomości" => Loc["CatRealEstate"],
        "Zakupy"        => Loc["CatShopping"],
        "Praca"         => Loc["CatWork"],
        _               => cat ?? ""
    };
    private List<string> selectedPlatforms = new();

    private async Task SelectCategory(string cat)
    {
        if (_selectedCategory == cat) return;
        _selectedCategory = cat;

        // Reset form fields
        searchedText = string.Empty;
        requestNumbers = 0;
        isSendingHourChecked = false;
        isCyclicMessagingChecked = false;
        dateSendingNotification = null;
        minutesAfterSendingNotification = 0;
        isSprzedaz = isWynajem = isPrywatne = isPubliczne = isOstatnie24h = isDowolna = false;
        additional_phrase = string.Empty;

        // Re-filter platforms from loaded subscriptions for new category
        selectedPlatforms = platformSubscriptions
            .Where(p => p.Enabled)
            .Select(p => ActivePlatforms.FirstOrDefault(a => a.Equals(p.PlatformName, StringComparison.OrdinalIgnoreCase)))
            .Where(name => !string.IsNullOrEmpty(name))
            .ToList()!;

        // Load saved config for new category
        if (userId > 0)
            await ApplyConfigForCategory();
    }

    private async Task LoadAllCategoryStatuses()
    {
        var allConfigs = await UserService.GetAllNotificationConfigsAsync(userId) ?? new();
        _categoryEnabled = allConfigs
            .Where(c => c.Category != null)
            .ToDictionary(c => c.Category!, c => c.Enabled);
    }

    private async Task ApplyConfigForCategory()
    {
        var savedConfig = await UserService.GetNotificationConfigAsync(userId, _selectedCategory);
        if (savedConfig == null) return;
        searchedText = savedConfig.Phrase;
        requestNumbers = savedConfig.RequestCount;
        if (string.IsNullOrEmpty(savedConfig.Schedule)) return;
        if (savedConfig.Schedule.StartsWith("Co ") && savedConfig.Schedule.EndsWith(" min")
            && int.TryParse(savedConfig.Schedule[3..^4], out var mins))
        {
            isCyclicMessagingChecked = true;
            minutesAfterSendingNotification = mins;
        }
        else if (savedConfig.Schedule.StartsWith("Codziennie o ")
            && DateTime.TryParse(savedConfig.Schedule[13..], out var dt))
        {
            isSendingHourChecked = true;
            dateSendingNotification = dt;
        }
    }

    private DateTime? dateSendingNotification = null;
    private string timeToSendingMail = string.Empty;
    private string searchedText = string.Empty;
    private int requestNumbers;

    private void TogglePlatform(string platform)
    {
        if (selectedPlatforms.Contains(platform))
            selectedPlatforms.Remove(platform);
        else
            selectedPlatforms.Add(platform);
    }

    private void OnCheckboxChanged(bool value)
    {
        var selectedOptions = new List<string>();

        if (isSprzedaz) selectedOptions.Add("sprzedaz");
        if (isWynajem) selectedOptions.Add("wynajem");
        if (isPrywatne) selectedOptions.Add("prywatne");
        if (isPubliczne) selectedOptions.Add("publiczne");
        if (isOstatnie24h) selectedOptions.Add("ostatnie24h");
        if (isDowolna) selectedOptions.Add("dowolna");

        additional_phrase = string.Join(" ", selectedOptions);
    }

    private void OnCheckboxHourChanged(bool value)
    {
        setSendingHourPreview = !value;
        dateSendingNotification = value ? DateTime.Now : null;
        isCyclicMessagingChecked = !value;
        repeatRequestAfterTimePreview = value;
        minutesAfterSendingNotification = 0;
        StateHasChanged();
    }

    private void OnCheckboxCyclicChanged(bool value)
    {
        repeatRequestAfterTimePreview = !value;
        if (value) minutesAfterSendingNotification = 1;
        setSendingHourPreview = value;
        isSendingHourChecked = !value;
        dateSendingNotification = null;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var login = await LocalStorage.GetItemAsync<string>("login") ?? string.Empty;
        var token = await LocalStorage.GetItemAsync<string>("authToken") ?? string.Empty;
        if (string.IsNullOrEmpty(login) || string.IsNullOrEmpty(token)) { Navigation.NavigateTo("/login"); return; }

        Globals.IsLogged = true;
        Globals.AuthToken = token;

        var userInfo = await LoginProxy.GetUser(login);
        if (userInfo == null || userInfo.user_id <= 0) { Navigation.NavigateTo("/login"); return; }
        userId = userInfo.user_id;
        Globals.UserId = userId;

        allChannels = await UserService.GetAllChannelsAsync() ?? new();
        allPlatforms = await UserService.GetAllPlatformsAsync() ?? new();

        foreach (var channel in allChannels)
        {
            var name = channel.Name.ToLower();
            if (name.Contains("email")) _emailChannelId = channel.Id;
            else if (name.Contains("sms") || name.Contains("text")) _smsChannelId = channel.Id;
            else if (name.Contains("discord")) _discordChannelId = channel.Id;
            else if (name.Contains("inapp") || name.Contains("app")) _inAppChannelId = channel.Id;
        }

        notificationChannels = await UserService.GetUserNotificationSettingsAsync(userId) ?? new();
        foreach (var channel in notificationChannels)
        {
            var name = channel.ChannelName.ToLower();
            if (name.Contains("email")) isEmailChecked = channel.Enabled;
            else if (name.Contains("sms") || name.Contains("text")) isSMSChecked = channel.Enabled;
            else if (name.Contains("discord")) isDiscordChecked = channel.Enabled;
            else if (name.Contains("inapp") || name.Contains("app")) isInAppChecked = channel.Enabled;
        }

        platformSubscriptions = await UserService.GetUserPlatformSubscriptionsAsync(userId) ?? new();
        selectedPlatforms = platformSubscriptions
            .Where(p => p.Enabled)
            .Select(p => availablePlatforms.FirstOrDefault(a => a.Equals(p.PlatformName, StringComparison.OrdinalIgnoreCase)) ?? p.PlatformName)
            .Where(name => !string.IsNullOrEmpty(name))
            .ToList();

        // Auto-detect category from loaded platforms so user doesn't have to click
        if (selectedPlatforms.Any(p => _carPlatforms.Any(c => c.Equals(p, StringComparison.OrdinalIgnoreCase))))
            _selectedCategory = "Motoryzacja";
        else if (selectedPlatforms.Any(p => _flatPlatforms.Any(f => f.Equals(p, StringComparison.OrdinalIgnoreCase))))
            _selectedCategory = "Nieruchomości";
        else if (selectedPlatforms.Any(p => _shopPlatforms.Any(s => s.Equals(p, StringComparison.OrdinalIgnoreCase))))
            _selectedCategory = "Zakupy";

        // Keep only platforms belonging to detected category
        if (!string.IsNullOrEmpty(_selectedCategory))
            selectedPlatforms = selectedPlatforms
                .Where(p => ActivePlatforms.Any(a => a.Equals(p, StringComparison.OrdinalIgnoreCase)))
                .ToList();

        await LoadJobs();
        await LoadAllCategoryStatuses();
        await ApplyConfigForCategory();

        StateHasChanged();
    }

    private async Task LoadJobs()
    {
        if (userId <= 0) return;
        var result = await NotificationProxy.GetJobsForUser(userId);
        userJobs = result?.Data ?? new();
        StateHasChanged();
    }

    private static string CronToHuman(string cron)
    {
        if (string.IsNullOrWhiteSpace(cron)) return "—";
        var parts = cron.Trim().Split(' ');
        if (parts.Length >= 5)
        {
            if (parts[0].StartsWith("*/") && int.TryParse(parts[0][2..], out var mins))
                return $"Co {mins} min";
            if (parts[0] == "0" && int.TryParse(parts[1], out var hour)
                && parts[2] == "*" && parts[3] == "*" && parts[4] == "*")
                return $"Codziennie o {hour:D2}:00";
            if (parts[0] == "0" && parts[1] == "0" && parts[2] == "*")
                return "Codziennie o północy";
        }
        return cron;
    }

    private static (string label, string css) StateDisplay(string? state) => state?.ToLower() switch
    {
        "succeeded" => ("OK", "job-state--ok"),
        "failed"    => ("Błąd", "job-state--err"),
        "enqueued"  => ("W kolejce", "job-state--queued"),
        "processing"=> ("W toku", "job-state--processing"),
        _           => (state ?? "—", "job-state--unknown")
    };

    private async Task SaveConfiguration()
    {
        try
        {
            if (userId <= 0)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Błąd: Nie można uzyskać identyfikatora użytkownika.");
                return;
            }
            if (string.IsNullOrEmpty(_selectedCategory))
            {
                NotificationService.Notify(NotificationSeverity.Error, "Błąd: Wybierz kategorię (Motoryzacja / Nieruchomości / Zakupy).");
                return;
            }
            if (requestNumbers <= 0)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Błąd: Ilość szukanych wpisów musi być większa niż 0.");
                return;
            }
            if (string.IsNullOrEmpty(searchedText))
            {
                NotificationService.Notify(NotificationSeverity.Error, "Błąd: Nie podano szukanego tekstu.");
                return;
            }
            if (!Globals.IsPhraseValid(searchedText))
            {
                NotificationService.Notify(NotificationSeverity.Error, "Błąd: Fraza zawiera niedozwolone znaki. Dozwolone: litery, cyfry, spacje, myślnik.");
                return;
            }
            if (!selectedPlatforms.Any())
            {
                NotificationService.Notify(NotificationSeverity.Error, "Błąd: Nie wybrano platformy do pobrania danych.");
                return;
            }

            var hourToSend = dateSendingNotification?.ToString("HH:mm");
            var repeatMinutes = minutesAfterSendingNotification > 0 ? (int?)minutesAfterSendingNotification : null;

            if (repeatMinutes != null && !string.IsNullOrEmpty(hourToSend))
            {
                NotificationService.Notify(NotificationSeverity.Error, "Błąd: Nie można ustawić obydwu właściwości jednocześnie.");
                return;
            }

            if (_emailChannelId > 0)
                await UserService.UpdateNotificationSettingAsync(userId, _emailChannelId, isEmailChecked);
            if (_smsChannelId > 0)
                await UserService.UpdateNotificationSettingAsync(userId, _smsChannelId, isSMSChecked);
            if (_discordChannelId > 0)
                await UserService.UpdateNotificationSettingAsync(userId, _discordChannelId, isDiscordChecked);
            if (_inAppChannelId > 0)
                await UserService.UpdateNotificationSettingAsync(userId, _inAppChannelId, isInAppChecked);

            foreach (var platform in allPlatforms)
            {
                if (!ActivePlatforms.Any(cp => cp.Equals(platform.Name, StringComparison.OrdinalIgnoreCase)))
                    continue;
                if (!selectedPlatforms.Any(p => p.Equals(platform.Name, StringComparison.OrdinalIgnoreCase)))
                    continue; // don't disable — only enable selected
                await UserService.UpdatePlatformSubscriptionAsync(userId, platform.Id, true);
            }

            var scheduleString = isSendingHourChecked && dateSendingNotification.HasValue
                ? $"Codziennie o {dateSendingNotification:HH:mm}"
                : isCyclicMessagingChecked && minutesAfterSendingNotification > 0
                    ? $"Co {minutesAfterSendingNotification} min"
                    : null;

            await UserService.SaveNotificationConfigAsync(new SaveNotificationConfigRequest
            {
                UserId = userId,
                Phrase = searchedText,
                RequestCount = requestNumbers,
                Schedule = scheduleString,
                Category = _selectedCategory
            });

            var request = new NotificationRequest
            {
                UserId = userId,
                Phrase = searchedText,
                AdditionalPhrase = string.IsNullOrWhiteSpace(additional_phrase) ? null : additional_phrase,
                RequestNumber = requestNumbers,
                HourToSendMail = hourToSend,
                RepeatAfterSpecifiedTime = repeatMinutes,
                Email = isEmailChecked,
                Sms = isSMSChecked,
                Discord = isDiscordChecked,
                InApp = isInAppChecked,
                Websites = selectedPlatforms.Select(p => p.ToLower()).ToList()
            };

            await NotificationProxy.setCronJob(request);
            await UserService.SetNotificationConfigEnabledAsync(userId, _selectedCategory, true);
            _categoryEnabled[_selectedCategory] = true;

            NotificationService.Notify(NotificationSeverity.Info, "Zmiany zapisano.");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, $"Błąd: {ex.Message}");
        }
    }

    private async Task DeleteJobs()
    {
        if (userId <= 0)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Błąd: Nie można uzyskać identyfikatora użytkownika.");
            return;
        }

        var result = await NotificationProxy.DeleteJobs(new DeleteJobModel { user_id = userId });

        if (result.success)
        {
            await UserService.SetNotificationConfigEnabledAsync(userId, _selectedCategory, false);
            _categoryEnabled[_selectedCategory] = false;
            NotificationService.Notify(NotificationSeverity.Success, result.message ?? "Sukces");
        }
        else
            NotificationService.Notify(NotificationSeverity.Error, result.message ?? "Błąd podczas usuwania jobów.");
    }
}
