@page "/reset-password"
@layout PublicLayout
@inject UserService UserService
@inject NavigationManager Navigation

<PageTitle>Reset hasła – Wyszukiwacz</PageTitle>

<style>
    .rp-wrap {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem 1rem;
    }

    .rp-card {
        background: white;
        border-radius: 20px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    }

    .rp-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1a1a2e;
        margin: 0 0 0.4rem;
        text-align: center;
    }

    .rp-sub {
        font-size: 0.9rem;
        color: #666;
        margin: 0 0 1.5rem;
        text-align: center;
    }

    .rp-field { margin-bottom: 1rem; }

    .rp-label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.4rem;
    }

    .rp-input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        font-size: 0.95rem;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

    .rp-input:focus { border-color: #667eea; }

    .rp-btn {
        width: 100%;
        padding: 0.9rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        margin-top: 0.5rem;
        transition: opacity 0.2s;
    }

    .rp-btn:disabled { opacity: 0.6; cursor: not-allowed; }

    .rp-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }

    .rp-success {
        background: #ecfdf5;
        border: 1px solid #6ee7b7;
        color: #065f46;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }

    .rp-back {
        display: block;
        text-align: center;
        margin-top: 1.25rem;
        color: #667eea;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
    }

    .rp-back:hover { color: #764ba2; }

    .rp-invalid {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #b91c1c;
        border-radius: 8px;
        padding: 1.5rem;
        text-align: center;
    }
</style>

<div class="rp-wrap">
    <div class="rp-card">
        <h1 class="rp-title">Reset hasła</h1>

        @if (_tokenMissing)
        {
            <div class="rp-invalid">
                <strong>Nieprawidłowy link.</strong><br />
                Link jest nieprawidłowy lub wygasł. Wróć do logowania i spróbuj ponownie.
            </div>
            <a href="/login" class="rp-back">← Wróć do logowania</a>
        }
        else if (_done)
        {
            <div class="rp-success">
                Hasło zostało zmienione. Możesz się teraz zalogować.
            </div>
            <a href="/login" class="rp-back">← Przejdź do logowania</a>
        }
        else
        {
            <p class="rp-sub">Wpisz nowe hasło dla swojego konta.</p>

            @if (!string.IsNullOrEmpty(_errorMsg))
            {
                <div class="rp-error">@_errorMsg</div>
            }

            <div class="rp-field">
                <label class="rp-label">Nowe hasło</label>
                <input type="password" class="rp-input" @bind="_newPassword" @bind:event="oninput"
                       placeholder="Min. 6 znaków" />
            </div>
            <div class="rp-field">
                <label class="rp-label">Potwierdź nowe hasło</label>
                <input type="password" class="rp-input" @bind="_confirmPassword" @bind:event="oninput"
                       placeholder="Powtórz nowe hasło" />
            </div>

            <button class="rp-btn" disabled="@(!CanSubmit)" @onclick="Submit">
                @if (_busy) { <span>Zmieniam...</span> } else { <span>Zmień hasło</span> }
            </button>

            <a href="/login" class="rp-back">← Wróć do logowania</a>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _errorMsg;
    private bool _busy;
    private bool _done;
    private bool _tokenMissing;

    private bool CanSubmit =>
        !_busy &&
        _newPassword.Length >= 6 &&
        _newPassword == _confirmPassword;

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(Token))
            _tokenMissing = true;
    }

    private async Task Submit()
    {
        _errorMsg = null;
        if (_newPassword != _confirmPassword)
        {
            _errorMsg = "Nowe hasła nie są identyczne.";
            return;
        }
        if (_newPassword.Length < 6)
        {
            _errorMsg = "Nowe hasło musi mieć co najmniej 6 znaków.";
            return;
        }

        _busy = true;
        StateHasChanged();

        var (success, msg) = await UserService.ResetPasswordByTokenAsync(Token!, _newPassword);
        _busy = false;

        if (success)
            _done = true;
        else
            _errorMsg = msg ?? "Wystąpił błąd. Spróbuj ponownie.";

        StateHasChanged();
    }
}
