@page "/login"
@layout PublicLayout
@using WyszukiwaczAppDTO
@using WyszukiwaczApp
@inject UserService UserService
@inject NavigationManager NavigationManager
@inject ILocalStorageService LocalStorage

<PageTitle>Logowanie – Wyszukiwacz</PageTitle>

<div class="auth-page">
    <div class="auth-split">

        <!-- Left branding panel (hidden on mobile) -->
        <div class="auth-brand" aria-hidden="true">
            <div class="auth-brand-inner">
                <div class="auth-brand-logo">🔍</div>
                <h2 class="auth-brand-title">Witaj z powrotem!</h2>
                <p class="auth-brand-desc">Tysiące ofert z OLX, Otomoto, Otodom i Amazona – monitorowane za Ciebie automatycznie.</p>
                <div class="auth-brand-stats">
                    <div class="auth-stat"><span class="auth-stat-n">12+</span><span>portali</span></div>
                    <div class="auth-stat"><span class="auth-stat-n">5 min</span><span>odświeżanie</span></div>
                    <div class="auth-stat"><span class="auth-stat-n">24/7</span><span>monitoring</span></div>
                </div>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="auth-form-wrap">
            <a href="/" class="auth-back-link">← Strona główna</a>

            <div class="auth-card">
                <div class="auth-card-header">
                    <h1 class="auth-card-title">Zaloguj się</h1>
                    <p class="auth-card-sub">Nie masz konta? <a href="/register">Zarejestruj się bezpłatnie</a></p>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="auth-error">
                        <span class="auth-error-icon">⚠</span>
                        @errorMessage
                    </div>
                }

                <EditForm Model="@loginModel" OnValidSubmit="OnLogin">
                    <DataAnnotationsValidator />

                    <div class="auth-field">
                        <label class="auth-label" for="login">Email lub login</label>
                        <InputText id="login" @bind-Value="loginModel.Login" class="auth-input" placeholder="twoj@email.pl lub login" />
                        <ValidationMessage For="@(() => loginModel.Login)" />
                    </div>

                    <div class="auth-field">
                        <label class="auth-label" for="password">Hasło</label>
                        <InputText id="password" @bind-Value="loginModel.Password" type="password"
                                   class="auth-input" placeholder="Wprowadź hasło"
                                   @onkeydown="HandlePasswordKeyDown" />
                        <ValidationMessage For="@(() => loginModel.Password)" />
                    </div>

                    <div class="auth-remember">
                        <label class="auth-checkbox-label">
                            <input type="checkbox" @bind="rememberMe" class="auth-checkbox" />
                            <span>Zapamiętaj mnie</span>
                        </label>
                    </div>

                    <button type="submit" class="auth-submit" disabled="@(isLoading || string.IsNullOrEmpty(loginModel.Password))">
                        @if (isLoading)
                        {
                            <span class="auth-spinner"></span>
                            <span>Logowanie...</span>
                        }
                        else
                        {
                            <span>Zaloguj się</span>
                        }
                    </button>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private bool isLoading = false;
    private bool rememberMe = false;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        Globals.IsLogged = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var savedLogin    = await LocalStorage.GetItemAsync<string>("rememberedLogin");
        var savedPassword = await LocalStorage.GetItemAsync<string>("rememberedPassword");
        if (!string.IsNullOrEmpty(savedLogin))
        {
            loginModel.Login    = savedLogin;
            loginModel.Password = savedPassword ?? string.Empty;
            rememberMe = true;
            StateHasChanged();
        }
    }

    private async Task HandlePasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(loginModel.Password))
            await OnLogin();
    }

    private async Task OnLogin()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            StateHasChanged();

            var result = await UserService.LoginAsync(loginModel.Login, loginModel.Password);

            if (result?.Success == true && !string.IsNullOrEmpty(result.Token))
            {
                Globals.IsLogged = true;
                Globals.Login = loginModel.Login;
                Globals.AuthToken = result.Token;

                await LocalStorage.SetItemAsync("authToken", result.Token);
                await LocalStorage.SetItemAsync("login", loginModel.Login);

                if (rememberMe)
                {
                    await LocalStorage.SetItemAsync("rememberedLogin", loginModel.Login);
                    await LocalStorage.SetItemAsync("rememberedPassword", loginModel.Password);
                }
                else
                {
                    await LocalStorage.RemoveItemAsync("rememberedLogin");
                    await LocalStorage.RemoveItemAsync("rememberedPassword");
                }

                NavigationManager.NavigateTo("/");
            }
            else
            {
                errorMessage = result?.Message ?? "Nieprawidłowy login lub hasło";
            }
        }
        catch
        {
            errorMessage = "Niepoprawne dane logowania";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    class LoginModel
    {
        public string Login { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
