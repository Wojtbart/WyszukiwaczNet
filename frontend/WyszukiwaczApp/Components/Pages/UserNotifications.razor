@page "/powiadomienia"
@layout MainLayout
@using WyszukiwaczAppDTO
@using WyszukiwaczApp
@inject UserService UserService
@inject NavigationManager NavigationManager

<style>
    .feed-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .feed-header h2 {
        margin: 0;
        font-weight: 600;
        color: #333;
    }

    .btn-mark-read {
        padding: 0.5rem 1rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .btn-mark-read:hover {
        opacity: 0.85;
    }

    .feed-empty {
        text-align: center;
        padding: 3rem;
        color: #999;
        font-size: 1.1rem;
    }

    .feed-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .feed-item {
        background: white;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
        display: flex;
        align-items: center;
        gap: 1rem;
        border-left: 4px solid transparent;
        transition: box-shadow 0.2s;
    }

    .feed-item.unread {
        border-left-color: #667eea;
        background: #f7f8ff;
    }

    .feed-item:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    }

    .feed-item-platform {
        font-size: 0.75rem;
        font-weight: 600;
        color: #764ba2;
        background: #f0ecff;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        white-space: nowrap;
    }

    .feed-item-body {
        flex: 1;
        min-width: 0;
    }

    .feed-item-title {
        font-weight: 500;
        color: #222;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .feed-item-meta {
        font-size: 0.82rem;
        color: #888;
        margin-top: 0.2rem;
    }

    .feed-item-price {
        font-weight: 600;
        color: #333;
        white-space: nowrap;
    }

    .feed-item-link {
        color: #667eea;
        text-decoration: none;
        font-size: 0.9rem;
        white-space: nowrap;
    }

    .feed-item-link:hover {
        text-decoration: underline;
    }

    .feed-item-date {
        font-size: 0.78rem;
        color: #bbb;
        white-space: nowrap;
    }
</style>

<div class="feed-header">
    <h2>Powiadomienia</h2>
    @if (unreadCount > 0)
    {
        <button class="btn-mark-read" @onclick="MarkAllRead">Oznacz jako przeczytane (@unreadCount)</button>
    }
</div>

@if (isLoading)
{
    <p>Ładowanie...</p>
}
else if (items == null || items.Count == 0)
{
    <div class="feed-empty">Brak powiadomień</div>
}
else
{
    <div class="feed-list">
        @foreach (var item in items)
        {
            <div class="feed-item @(item.Status == "new" ? "unread" : "")">
                @if (!string.IsNullOrEmpty(item.PlatformName))
                {
                    <span class="feed-item-platform">@item.PlatformName</span>
                }
                <div class="feed-item-body">
                    <div class="feed-item-title">@(item.OfferTitle ?? "Oferta")</div>
                    <div class="feed-item-meta">
                        @if (!string.IsNullOrEmpty(item.OfferLocation))
                        {
                            <span>@item.OfferLocation</span>
                        }
                    </div>
                </div>
                @if (item.OfferPrice.HasValue)
                {
                    <span class="feed-item-price">@item.OfferPrice.Value.ToString("N0") PLN</span>
                }
                @if (!string.IsNullOrEmpty(item.OfferUrl))
                {
                    <a class="feed-item-link" href="@item.OfferUrl" target="_blank">Otwórz</a>
                }
                <span class="feed-item-date">@item.CreatedAt.ToLocalTime().ToString("dd.MM HH:mm")</span>
            </div>
        }
    </div>
}

@code {
    private List<NotificationFeedItemDto>? items;
    private int unreadCount;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!Globals.IsLogged || Globals.UserId == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadFeed();
    }

    private async Task LoadFeed()
    {
        isLoading = true;
        var result = await UserService.GetNotificationFeedAsync(Globals.UserId!.Value);
        items = result?.Data ?? new();
        unreadCount = result?.UnreadCount ?? 0;
        isLoading = false;
    }

    private async Task MarkAllRead()
    {
        await UserService.MarkNotificationsReadAsync(Globals.UserId!.Value);
        unreadCount = 0;
        if (items != null)
            foreach (var i in items) i.Status = "read";
    }
}
