 <style>
    /* Container for notification icon and dropdown */
    .notification-container {
        position: relative;
    }

    /* Notification Icon */
    .notification-icon {
        position: relative;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.5em;
    }

    .notification-count {
        position: absolute;
        top: -5px;
        right: -5px;
        background-color: red;
        color: white;
        border-radius: 50%;
        padding: 3px 6px;
        font-size: 0.75em;
    }

    /* Notification Dropdown */
    .notification-dropdown {
        position: absolute;
        top: 40px;
        right: 0;
        width: 300px;
        background: white;
        border: 1px solid #ddd;
        border-radius: 8px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        z-index: 10;
    }

    .notification-header {
        display: flex;
        justify-content: space-between;
        padding: 10px;
        border-bottom: 1px solid #ddd;
    }

        .notification-header h3 {
            margin: 0;
            font-size: 1em;
        }

    .close-btn {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.2em;
        color: #888;
    }

    /* Notification List */
    .notification-list {
        list-style: none;
        margin: 0;
        padding: 0;
        max-height: 200px;
        overflow-y: auto;
    }

    .notification-item {
        display: flex;
        padding: 10px;
        border-bottom: 1px solid #f0f0f0;
    }

    .notification-text p {
        margin: 0;
        font-size: 0.9em;
    }

    .notification-time {
        font-size: 0.75em;
        color: #888;
    }

    /* Notification Footer */
    .notification-footer {
        text-align: center;
        padding: 10px;
    }

    .view-all {
        text-decoration: none;
        color: #007bff;
        font-size: 0.9em;
    }
 </style>

<div class="notification-container">
    <!-- Notification Icon Button -->
    <button @onclick="ToggleNotificationDropdown" class="notification-icon">
        <span class="icon-bell">🔔</span>
        @if (notifications.Count > 0)
        {
            <span class="notification-count">@notifications.Count</span>
        }
    </button>

    <!-- Notification Dropdown -->
    @if (isNotificationOpen)
    {
        <div class="notification-dropdown">
            <div class="notification-header">
                <h3>Notifications</h3>
                <button class="close-btn" @onclick="CloseNotificationDropdown">✕</button>
            </div>

            <!-- Notification Items -->
            <ul class="notification-list">
                @foreach (var notification in notifications)
                {
                    <li class="notification-item">
                        <div class="notification-text">
                            <p>@notification.Title</p>
                            <span class="notification-time">@notification.Time</span>
                        </div>
                    </li>
                }
            </ul>

            <!-- "View All" link -->
            <div class="notification-footer">
                <a href="#" class="view-all">View All Notifications</a>
            </div>
        </div>
    }
</div>
@code {
    private bool isNotificationOpen = false;

    // Sample data for notifications
    private List<Notification> notifications = new()
    {
        new Notification { Id = 1, Title = "New message from Alice", Time = "5 mins ago" },
        new Notification { Id = 2, Title = "John liked your post", Time = "10 mins ago" },
        new Notification { Id = 3, Title = "You have a new follower", Time = "1 hour ago" }
    };

    // Toggles the notification dropdown visibility
    private void ToggleNotificationDropdown()
    {
        isNotificationOpen = !isNotificationOpen;
    }

    // Closes the notification dropdown
    private void CloseNotificationDropdown()
    {
        isNotificationOpen = false;
    }

    // Notification model
    public class Notification
    {
        public int Id { get; set; }
        public string Title { get; set; }
        public string Time { get; set; }
    }
}