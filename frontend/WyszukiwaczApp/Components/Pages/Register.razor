@page "/register"
@layout PublicLayout
@using WyszukiwaczAppDTO
@using WyszukiwaczApp
@using System.ComponentModel.DataAnnotations
@inject UserService UserService
@inject NavigationManager NavigationManager

<PageTitle>Rejestracja – Wyszukiwacz</PageTitle>

<div class="auth-page">
    <div class="auth-split">

        <!-- Left branding panel -->
        <div class="auth-brand" aria-hidden="true">
            <div class="auth-brand-inner">
                <div class="auth-brand-logo">🔍</div>
                <h2 class="auth-brand-title">Dołącz do Wyszukiwacza</h2>
                <p class="auth-brand-desc">Rejestracja jest bezpłatna. Zacznij monitorować oferty na dziesiątkach portali w minutę.</p>
                <ul class="auth-brand-perks">
                    <li>✅ Darmowy plan bez limitu czasu</li>
                    <li>✅ Alerty email gdy pojawi się okazja</li>
                    <li>✅ Wyszukiwanie na OLX, Otomoto, Otodom</li>
                    <li>✅ Bez karty kredytowej</li>
                </ul>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="auth-form-wrap">
            <a href="/" class="auth-back-link">← Strona główna</a>

            <div class="auth-card">
                <div class="auth-card-header">
                    <h1 class="auth-card-title">Utwórz konto</h1>
                    <p class="auth-card-sub">Masz już konto? <a href="/login">Zaloguj się</a></p>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="auth-error">
                        <span class="auth-error-icon">⚠</span>
                        @errorMessage
                    </div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="auth-success">
                        ✅ @successMessage
                    </div>
                }

                <EditForm Model="@registerModel" OnValidSubmit="OnRegister">
                    <DataAnnotationsValidator />

                    <div class="auth-field-row">
                        <div class="auth-field">
                            <label class="auth-label" for="name">Imię</label>
                            <InputText id="name" @bind-Value="registerModel.Name" class="auth-input" placeholder="Jan" />
                        </div>
                        <div class="auth-field">
                            <label class="auth-label" for="surname">Nazwisko</label>
                            <InputText id="surname" @bind-Value="registerModel.Surname" class="auth-input" placeholder="Kowalski" />
                        </div>
                    </div>

                    <div class="auth-field">
                        <label class="auth-label" for="login">Login <span class="auth-required">*</span></label>
                        <InputText id="login" @bind-Value="registerModel.Login" class="auth-input" placeholder="Nazwa użytkownika" />
                        <ValidationMessage For="@(() => registerModel.Login)" />
                    </div>

                    <div class="auth-field">
                        <label class="auth-label" for="email">Email <span class="auth-required">*</span></label>
                        <InputText id="email" @bind-Value="registerModel.Email" class="auth-input" placeholder="twoj@email.pl" />
                        <ValidationMessage For="@(() => registerModel.Email)" />
                    </div>

                    <div class="auth-field">
                        <label class="auth-label" for="phone">Telefon <span class="auth-optional">(opcjonalnie)</span></label>
                        <InputText id="phone" @bind-Value="registerModel.Phone" class="auth-input" placeholder="+48123456789" />
                        <ValidationMessage For="@(() => registerModel.Phone)" />
                    </div>

                    <div class="auth-field">
                        <label class="auth-label" for="password">Hasło <span class="auth-required">*</span></label>
                        <InputText id="password" @bind-Value="registerModel.Password" type="password" class="auth-input" placeholder="Min. 6 znaków" />
                        <ValidationMessage For="@(() => registerModel.Password)" />
                    </div>

                    <div class="auth-field">
                        <label class="auth-label" for="repeatPassword">Powtórz hasło <span class="auth-required">*</span></label>
                        <InputText id="repeatPassword" @bind-Value="registerModel.RepeatPassword" type="password" class="auth-input" placeholder="Powtórz hasło" />
                        <ValidationMessage For="@(() => registerModel.RepeatPassword)" />
                    </div>

                    <button type="submit" class="auth-submit" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="auth-spinner"></span>
                            <span>Rejestracja...</span>
                        }
                        else
                        {
                            <span>Zarejestruj się bezpłatnie</span>
                        }
                    </button>

                    <p class="auth-terms">
                        Rejestrując się akceptujesz <a href="/">regulamin</a> i <a href="/">politykę prywatności</a>.
                    </p>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;

    protected override void OnInitialized()
    {
        Globals.IsLogged = false;
    }

    private async Task OnRegister()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            successMessage = null;
            StateHasChanged();

            var request = new RegisterUserRequest
            {
                Email = registerModel.Email,
                Phone = registerModel.Phone,
                Password = registerModel.Password,
                Login = registerModel.Login,
                Name = registerModel.Name ?? string.Empty,
                Surname = registerModel.Surname ?? string.Empty
            };

            var result = await UserService.RegisterAsync(request);

            if (result?.Success == true)
            {
                successMessage = "Rejestracja zakończona pomyślnie! Przekierowuję do logowania...";
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                errorMessage = result?.Message ?? "Rejestracja nie powiodła się";
            }
        }
        catch
        {
            errorMessage = "Wystąpił błąd podczas rejestracji.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    class RegisterModel
    {
        public string? Name { get; set; }
        public string? Surname { get; set; }

        [Required(ErrorMessage = "Login jest wymagany")]
        [MinLength(3, ErrorMessage = "Login musi mieć min. 3 znaki")]
        public string Login { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email jest wymagany")]
        [EmailAddress(ErrorMessage = "Nieprawidłowy format email")]
        public string Email { get; set; } = string.Empty;

        [RegularExpression(@"^(\+\d{2})?\d{9}$", ErrorMessage = "Telefon musi mieć 9 cyfr lub format +48XXXXXXXXX")]
        public string? Phone { get; set; }

        [Required(ErrorMessage = "Hasło jest wymagane")]
        [MinLength(6, ErrorMessage = "Hasło musi mieć min. 6 znaków")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Powtórz hasło")]
        [Compare(nameof(Password), ErrorMessage = "Hasła nie są identyczne")]
        public string RepeatPassword { get; set; } = string.Empty;
    }
}
