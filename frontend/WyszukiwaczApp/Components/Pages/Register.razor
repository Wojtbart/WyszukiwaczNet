@page "/register"
@layout PublicLayout
@using WyszukiwaczAppDTO
@using WyszukiwaczApp
@using System.ComponentModel.DataAnnotations
@inject UserService UserService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> Loc
@inject WyszukiwaczApp.Services.AuthState AuthState

<PageTitle>@Loc["RegisterPageTitle"]</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-card-title">@Loc["RegisterTitle"]</h1>
        <p class="auth-card-sub">@Loc["RegisterHasAccount"] <a href="/login">@Loc["SignIn"]</a></p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="auth-error">
                <span>⚠</span>
                @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="auth-success">
                ✅ @successMessage
            </div>
        }

        <EditForm Model="@registerModel" OnValidSubmit="OnRegister">
            <DataAnnotationsValidator />

            <div class="auth-field-row">
                <div class="auth-field">
                    <label class="auth-label" for="name">@Loc["FirstName"]</label>
                    <div class="auth-input-group">
                        <i class="material-icons auth-input-icon">badge</i>
                        <input id="name" @bind="registerModel.Name" class="auth-input" placeholder="Jan" />
                    </div>
                </div>
                <div class="auth-field">
                    <label class="auth-label" for="surname">@Loc["LastName"]</label>
                    <div class="auth-input-group">
                        <i class="material-icons auth-input-icon">badge</i>
                        <input id="surname" @bind="registerModel.Surname" class="auth-input" placeholder="Kowalski" />
                    </div>
                </div>
            </div>

            <div class="auth-field">
                <label class="auth-label" for="login">@Loc["UsernameLabel"] <span class="auth-required">*</span></label>
                <div class="auth-input-group">
                    <i class="material-icons auth-input-icon">person</i>
                    <input id="login" @bind="registerModel.Login" class="auth-input" placeholder="@(Loc["UsernamePlaceholder"].Value)" />
                </div>
            </div>

            <div class="auth-field">
                <label class="auth-label" for="email">Email <span class="auth-required">*</span></label>
                <div class="auth-input-group">
                    <i class="material-icons auth-input-icon">email</i>
                    <input id="email" type="email" @bind="registerModel.Email" class="auth-input" placeholder="twoj@email.pl" />
                </div>
            </div>

            <div class="auth-field">
                <label class="auth-label" for="phone">@Loc["Phone"] <span class="auth-optional">@Loc["Optional"]</span></label>
                <div class="auth-input-group">
                    <i class="material-icons auth-input-icon">phone</i>
                    <input id="phone" type="tel" @bind="registerModel.Phone" class="auth-input" placeholder="+48123456789" />
                </div>
            </div>

            <div class="auth-field">
                <label class="auth-label" for="password">@Loc["PasswordLabel"] <span class="auth-required">*</span></label>
                <div class="auth-input-group">
                    <i class="material-icons auth-input-icon">lock</i>
                    <input id="password" type="password" @bind="registerModel.Password" class="auth-input" placeholder="@(Loc["PasswordMinHint"].Value)" />
                </div>
            </div>

            <div class="auth-field">
                <label class="auth-label" for="repeatPassword">@Loc["RepeatPasswordLabel"] <span class="auth-required">*</span></label>
                <div class="auth-input-group">
                    <i class="material-icons auth-input-icon">lock_reset</i>
                    <input id="repeatPassword" type="password" @bind="registerModel.RepeatPassword" class="auth-input" placeholder="@(Loc["RepeatPasswordLabel"].Value)" />
                </div>
            </div>

            <button type="submit" class="auth-submit" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="auth-spinner"></span>
                    <span>@Loc["Registering"]</span>
                }
                else
                {
                    <span>@Loc["RegisterButton"]</span>
                }
            </button>

            <p class="auth-terms">
                @Loc["TermsAccept"] <a href="/">@Loc["TermsOfService"]</a> i <a href="/">@Loc["PrivacyPolicy"]</a>.
            </p>
        </EditForm>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;

    protected override void OnInitialized()
    {
        AuthState.IsLogged = false;
    }

    private async Task OnRegister()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            successMessage = null;
            StateHasChanged();

            var request = new RegisterUserRequest
            {
                Email = registerModel.Email,
                Phone = registerModel.Phone,
                Password = registerModel.Password,
                Login = registerModel.Login,
                Name = registerModel.Name ?? string.Empty,
                Surname = registerModel.Surname ?? string.Empty
            };

            var result = await UserService.RegisterAsync(request);

            if (result?.Success == true)
            {
                successMessage = Loc["RegisterSuccessMsg"].Value;
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                errorMessage = result?.Message ?? Loc["RegisterFailedMsg"].Value;
            }
        }
        catch
        {
            errorMessage = Loc["RegisterGenericError"].Value;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    class RegisterModel
    {
        public string? Name { get; set; }
        public string? Surname { get; set; }

        [Required(ErrorMessage = "Login jest wymagany")]
        [MinLength(3, ErrorMessage = "Login musi mieć min. 3 znaki")]
        public string Login { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email jest wymagany")]
        [EmailAddress(ErrorMessage = "Nieprawidłowy format email")]
        public string Email { get; set; } = string.Empty;

        [RegularExpression(@"^(\+\d{2})?\d{9}$", ErrorMessage = "Telefon musi mieć 9 cyfr lub format +48XXXXXXXXX")]
        public string? Phone { get; set; }

        [Required(ErrorMessage = "Hasło jest wymagane")]
        [MinLength(6, ErrorMessage = "Hasło musi mieć min. 6 znaków")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Powtórz hasło")]
        [Compare(nameof(Password), ErrorMessage = "Hasła nie są identyczne")]
        public string RepeatPassword { get; set; } = string.Empty;
    }
}
