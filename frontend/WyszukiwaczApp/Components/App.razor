<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="utf-8" />
    <title>Wyszukiwacz – Agregator Ogłoszeń: Auta, Mieszkania, Zakupy</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Wyszukiwacz to polski agregator ogłoszeń. Szukaj aut na Otomoto i OLX, mieszkań na Otodom, produktów na Amazon – wszystko w jednym miejscu. Ustaw alert i bądź pierwszy przy nowych ofertach." />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="WyszukiwaczApp.styles.css" />

    <link id="radzen-theme-css" rel="stylesheet" href="_content/Radzen.Blazor/css/standard.css"/>
    @* <link rel="stylesheet" href="_content/Radzen.Blazor/css/dark-base.css"/>  *@
    @* <link rel="stylesheet" href="_content/Radzen.Blazor/css/humanistic-base.css"/> *@
    @* <link rel="stylesheet" href="_content/Rakdzen.Blazor/css/software-base.css"/>  *@
    @* <link rel="stylesheet" href="_content/Radzen.Blazor/css/default-base.css"/> *@
    @* <link rel="stylesheet" href="_content/Radzen.Blazor/css/material-base.css"> *@
    <link rel="stylesheet" href="app.css" />
    <script>
        (function () {
            var isDark = localStorage.getItem('radzen-theme') === 'dark';
            if (isDark) {
                var link = document.getElementById('radzen-theme-css');
                if (link) link.href = '_content/Radzen.Blazor/css/standard-dark.css';
                document.documentElement.classList.add('dark-mode');
            }
        })();

        window.setRadzenTheme = function (isDark) {
            var link = document.getElementById('radzen-theme-css');
            if (link) link.href = isDark
                ? '_content/Radzen.Blazor/css/standard-dark.css'
                : '_content/Radzen.Blazor/css/standard.css';
            document.documentElement.classList.toggle('dark-mode', isDark);
            localStorage.setItem('radzen-theme', isDark ? 'dark' : 'standard');
        };

        window.getRadzenThemeDark = function () {
            return localStorage.getItem('radzen-theme') === 'dark';
        };
    </script>

    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <div id="app-loading-overlay">
        <div class="app-spinner"></div>
    </div>
    <script src="_framework/blazor.web.js"></script>
    <script>
        window._appReady = false;

        window.appHideOverlay = function () {
            window._appReady = true;
            var el = document.getElementById('app-loading-overlay');
            if (el) el.remove();
        };

        new MutationObserver(function () {
            if (window._appReady) {
                var el = document.getElementById('app-loading-overlay');
                if (el) el.remove();
            }
        }).observe(document.documentElement, { childList: true, subtree: true });
    </script>
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js?v=@(typeof(Radzen.Colors).Assembly.GetName().Version)"></script>
</body>

</html>
