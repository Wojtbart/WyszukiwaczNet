@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject WyszukiwaczApp.Services.AuthState AuthState

<RadzenComponents />

<style>
    :root {
        --sidebar-width: 250px;
    }

    .app-layout {
        display: flex;
        min-height: 100vh;
    }

    .main-content {
        flex: 1;
        min-width: 0;
        overflow-x: hidden;
        background: #f5f5f5;
        min-height: 100vh;
        transition: background 0.3s;
    }

    .page-container {
        padding: 1.5rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    .auth-page {
        min-height: 100vh;
        min-width: 50vw;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .hamburger {
        display: none;
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 1100;
        background: #667eea;
        border: none;
        border-radius: 8px;
        padding: 8px 10px;
        cursor: pointer;
        flex-direction: column;
        gap: 5px;
    }

    .hamburger span {
        display: block;
        width: 24px;
        height: 2px;
        background: white;
        border-radius: 2px;
        transition: all 0.3s;
    }

    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        z-index: 999;
    }

    @@media (max-width: 768px) {
        .hamburger {
            display: flex;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            z-index: 1000;
            transform: translateX(-100%);
            transition: transform 0.3s ease;
        }

        .sidebar.sidebar--open {
            transform: translateX(0);
        }

        .nav-overlay {
            display: block;
        }

        .main-content {
            padding-top: 3.5rem;
        }
    }
</style>

@if (AuthState.IsLogged)
{
    <div class="app-layout">
        <button class="hamburger" @onclick="ToggleMenu" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        @if (_menuOpen)
        {
            <div class="nav-overlay" @onclick="CloseMenu"></div>
        }

        <div class="sidebar @(_menuOpen ? "sidebar--open" : "")">
            <NavMenu OnLinkClicked="CloseMenu" />
        </div>
        <div class="main-content">
            <div class="page-container">
                @Body
            </div>
        </div>
    </div>
}
else
{
    <div class="auth-page">
        @Body
    </div>
}

<div id="blazor-error-ui">
    Wystąpił nieoczekiwany błąd.
    <a href="" class="reload">Odśwież</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _menuOpen = false;
    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() { _menuOpen = false; StateHasChanged(); }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (uri == "login" || uri == "register") return;

        var token = await LocalStorage.GetItemAsync<string>("authToken");
        var login = await LocalStorage.GetItemAsync<string>("login");

        if (!string.IsNullOrEmpty(token))
        {
            AuthState.IsLogged = true;
            AuthState.AuthToken = token;
            AuthState.Login = login ?? string.Empty;
        }
        else
        {
            AuthState.IsLogged = false;
            AuthState.AuthToken = null;
            AuthState.Login = string.Empty;
            AuthState.UserId = null;
        }
        StateHasChanged();
    }
}
