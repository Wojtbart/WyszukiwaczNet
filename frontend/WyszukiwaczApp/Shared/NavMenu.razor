@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject UserService UserService
@inject IStringLocalizer<SharedResource> Loc
@inject IJSRuntime JS
@using WyszukiwaczApp
@implements IDisposable

<style>
    .nav-menu {
        background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
        padding: 1rem 0;
        min-height: 100vh;
        width: 250px;
    }
    
    .nav-brand {
        color: white;
        font-size: 1.5rem;
        font-weight: 700;
        padding: 0.5rem 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .nav-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
        border-radius: 0;
        margin-bottom: 0.25rem;
        transition: all 0.2s;
        cursor: pointer;
    }
    
    .nav-link:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }
    
    .nav-link.active {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        font-weight: 500;
        border-left: 4px solid white;
    }
    
    .nav-link-icon {
        font-size: 1.25rem;
        width: 24px;
        text-align: center;
    }
    
    .nav-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.2);
        margin: 1rem 0;
    }
    
    .user-info {
        padding: 1rem;
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.85rem;
        margin-top: auto;
    }
    
    .logout-btn {
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.85);
        cursor: pointer;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        text-align: left;
        transition: all 0.2s;
    }
    
    .logout-btn:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }

    .nav-badge {
        margin-left: auto;
        background: #ff4757;
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        min-width: 18px;
        height: 18px;
        border-radius: 9px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 5px;
    }

    .theme-toggle {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 20px;
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        font-size: 0.82rem;
        transition: background 0.2s;
        width: calc(100% - 2rem);
        margin: 0 1rem 0.5rem;
    }

    .theme-toggle:hover {
        background: rgba(255,255,255,0.25);
    }

</style>

<div class="nav-menu d-flex flex-column">
    <div class="nav-brand">
        🔍 Wyszukiwacz
    </div>

    <ul class="nav-links">
        <li>
            <NavLink href="/categories" class="nav-link" Match="NavLinkMatch.All" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">📁</span>
                @Loc["Categories"]
            </NavLink>
        </li>
        <li>
            <NavLink href="/notification" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">🔔</span>
                @Loc["Notifications"]
                @if (unreadCount > 0)
                {
                    <span class="nav-badge">@unreadCount</span>
                }
            </NavLink>
        </li>
        <li>
            <NavLink href="/history" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">📋</span>
                @Loc["History"]
            </NavLink>
        </li>

        <div class="nav-divider"></div>

        <li>
            <NavLink href="/account" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">👤</span>
                @Loc["MyAccount"]
            </NavLink>
        </li>
        <li>
            <NavLink href="/notification_settings" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">🔔</span>
                @Loc["NotificationSettings"]
            </NavLink>
        </li>

        <div class="nav-divider"></div>

        @if (!Globals.IsLogged)
        {
            <li>
                <NavLink href="/login" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                    <span class="nav-link-icon">🔑</span>
                    @Loc["Login"]
                </NavLink>
            </li>
            <li>
                <NavLink href="/register" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                    <span class="nav-link-icon">📝</span>
                    @Loc["Register"]
                </NavLink>
            </li>
        }
        else
        {
            <li>
                <button class="logout-btn" @onclick="Logout">
                    <span class="nav-link-icon">🚪</span>
                    @Loc["Logout"]
                </button>
            </li>
        }

    </ul>

    <div class="mt-auto">
        <button class="theme-toggle" @onclick="ToggleTheme">
            <span>@(_isDark ? "☀️" : "🌙")</span>
            <span>@(_isDark ? "Jasny motyw" : "Ciemny motyw")</span>
        </button>

        @if (Globals.IsLogged)
        {
            <div class="user-info">
                @Loc["LoggedAs"] @Globals.Login
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback OnLinkClicked { get; set; }

    private int unreadCount;
    private Timer? _timer;
    private bool _isDark = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDark = await JS.InvokeAsync<bool>("getRadzenThemeDark");
            Globals.NotificationsChanged += OnNotificationsChanged;

            _timer = new Timer(async _ =>
            {
                if (Globals.IsLogged && Globals.UserId.HasValue)
                {
                    var result = await UserService.GetNotificationFeedAsync(Globals.UserId.Value, 1);
                    var newCount = result?.UnreadCount ?? 0;
                    if (newCount != unreadCount)
                    {
                        unreadCount = newCount;
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }, null, TimeSpan.Zero, TimeSpan.FromSeconds(30));

            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("setRadzenTheme", _isDark);
    }

    private async void OnNotificationsChanged()
    {
        if (Globals.IsLogged && Globals.UserId.HasValue)
        {
            var result = await UserService.GetNotificationFeedAsync(Globals.UserId.Value, 1);
            unreadCount = result?.UnreadCount ?? 0;
        }
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Globals.NotificationsChanged -= OnNotificationsChanged;
        _timer?.Dispose();
    }

    private async Task Logout()
    {
        Globals.IsLogged = false;
        Globals.Login = string.Empty;
        Globals.AuthToken = null;
        _timer?.Dispose();
        await LocalStorage.RemoveItemAsync("authToken");
        Navigation.NavigateTo("/login", forceLoad: true);
    }

}
