@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@inject UserService UserService
@inject IStringLocalizer<SharedResource> Loc
@using WyszukiwaczApp
@implements IDisposable

<style>
    .nav-menu {
        background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
        padding: 1rem 0;
        min-height: 100vh;
        width: 250px;
    }
    
    .nav-brand {
        color: white;
        font-size: 1.5rem;
        font-weight: 700;
        padding: 0.5rem 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .nav-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
        border-radius: 0;
        margin-bottom: 0.25rem;
        transition: all 0.2s;
        cursor: pointer;
    }
    
    .nav-link:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }
    
    .nav-link.active {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        font-weight: 500;
        border-left: 4px solid white;
    }
    
    .nav-link-icon {
        font-size: 1.25rem;
        width: 24px;
        text-align: center;
    }
    
    .nav-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.2);
        margin: 1rem 0;
    }
    
    .user-info {
        padding: 1rem;
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.85rem;
        margin-top: auto;
    }
    
    .logout-btn {
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.85);
        cursor: pointer;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        text-align: left;
        transition: all 0.2s;
    }
    
    .logout-btn:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }

    .nav-badge {
        margin-left: auto;
        background: #ff4757;
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        min-width: 18px;
        height: 18px;
        border-radius: 9px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 5px;
    }

    .lang-switch {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        color: rgba(255, 255, 255, 0.85);
    }

    .lang-btn {
        color: rgba(255, 255, 255, 0.75);
        text-decoration: none;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid rgba(255, 255, 255, 0.25);
        transition: all 0.2s;
    }

    .lang-btn:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
        text-decoration: none;
    }

    .lang-btn.active {
        background: rgba(255, 255, 255, 0.25);
        color: white;
        border-color: white;
    }
</style>

<div class="nav-menu d-flex flex-column">
    <div class="nav-brand">
        🔍 Wyszukiwacz
    </div>

    <ul class="nav-links">
        <li>
            <NavLink href="/categories" class="nav-link" Match="NavLinkMatch.All" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">📁</span>
                @Loc["Categories"]
            </NavLink>
        </li>
        <li>
            <NavLink href="/notification" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">🔔</span>
                @Loc["Notifications"]
                @if (unreadCount > 0)
                {
                    <span class="nav-badge">@unreadCount</span>
                }
            </NavLink>
        </li>
        <li>
            <NavLink href="/offers" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">📋</span>
                @Loc["History"]
            </NavLink>
        </li>

        <div class="nav-divider"></div>

        <li>
            <NavLink href="/account" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">👤</span>
                @Loc["MyAccount"]
            </NavLink>
        </li>
        <li>
            <NavLink href="/notification_settings" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                <span class="nav-link-icon">🔔</span>
                @Loc["NotificationSettings"]
            </NavLink>
        </li>

        <div class="nav-divider"></div>

        @if (!Globals.IsLogged)
        {
            <li>
                <NavLink href="/login" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                    <span class="nav-link-icon">🔑</span>
                    @Loc["Login"]
                </NavLink>
            </li>
            <li>
                <NavLink href="/register" class="nav-link" @onclick="_ => OnLinkClicked.InvokeAsync()">
                    <span class="nav-link-icon">📝</span>
                    @Loc["Register"]
                </NavLink>
            </li>
        }
        else
        {
            <li>
                <button class="logout-btn" @onclick="Logout">
                    <span class="nav-link-icon">🚪</span>
                    @Loc["Logout"]
                </button>
            </li>
        }

        <div class="nav-divider"></div>

        <li class="lang-switch">
            <span class="nav-link-icon">🌐</span>
            <a href="@CultureLink("pl-PL")" class="lang-btn @(IsActive("pl-PL") ? "active" : "")">PL</a>
            <a href="@CultureLink("en-US")" class="lang-btn @(IsActive("en-US") ? "active" : "")">EN</a>
        </li>
    </ul>

    @if (Globals.IsLogged)
    {
        <div class="user-info mt-auto">
            @Loc["LoggedAs"] @Globals.Login
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback OnLinkClicked { get; set; }

    private int unreadCount;
    private Timer? _timer;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Globals.NotificationsChanged += OnNotificationsChanged;

            _timer = new Timer(async _ =>
            {
                if (Globals.IsLogged && Globals.UserId.HasValue)
                {
                    var result = await UserService.GetNotificationFeedAsync(Globals.UserId.Value, 1);
                    var newCount = result?.UnreadCount ?? 0;
                    if (newCount != unreadCount)
                    {
                        unreadCount = newCount;
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }, null, TimeSpan.Zero, TimeSpan.FromSeconds(30));
        }
    }

    private async void OnNotificationsChanged()
    {
        if (Globals.IsLogged && Globals.UserId.HasValue)
        {
            var result = await UserService.GetNotificationFeedAsync(Globals.UserId.Value, 1);
            unreadCount = result?.UnreadCount ?? 0;
        }
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Globals.NotificationsChanged -= OnNotificationsChanged;
        _timer?.Dispose();
    }

    private async Task Logout()
    {
        Globals.IsLogged = false;
        Globals.Login = string.Empty;
        Globals.AuthToken = null;
        _timer?.Dispose();
        await LocalStorage.RemoveItemAsync("authToken");
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private string CultureLink(string culture)
    {
        var uri = new Uri(Navigation.Uri);
        var redirect = uri.PathAndQuery;
        return $"/setculture?culture={culture}&redirectUri={Uri.EscapeDataString(redirect)}";
    }

    private bool IsActive(string culture) =>
        System.Globalization.CultureInfo.CurrentUICulture.Name.Equals(culture, StringComparison.OrdinalIgnoreCase);
}
